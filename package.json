{
  "name": "physics-mind",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:concepts": "tsx --env-file=.env.local src/scripts/seed-concepts.ts",
    "seed:comprehension-quiz": "tsx --env-file=.env.local src/scripts/seed-comprehension-quiz.ts",
    "extract:ncert": "node --env-file=.env.local src/scripts/extract-ncert.mjs",
    "test:stage2": "npx tsx --env-file=.env.local src/scripts/testStage2.ts",
    "mineru": "cd mineru-service && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:full": "concurrently \"npm run dev\" \"npm run mineru\"",
    "validate:concepts": "npx tsx src/scripts/validate-concepts.ts",
    "tts:translate": "npx tsx --env-file=.env.local src/scripts/translate_concept_tts.ts",
    "tts:generate": "npx tsx --env-file=.env.local src/scripts/generate_tts_audio.ts",
    "tts:rollout": "npx tsx --env-file=.env.local src/scripts/tts_rollout.ts",
    "build:review": "npx tsx src/scripts/build_review_site.ts",
    "review:all": "npx tsx src/scripts/build_review_site.ts --all",
    "catalog:refresh": "npx tsx src/scripts/build_review_site.ts --catalog",
    "serve:review": "npx --yes http-server review-site -p 8080 -c-1",
    "serve:site": "npx --yes http-server website -p 8090 -c-1",
    "deploy:review": "node src/scripts/deploy_review.mjs",
    "deploy:cf-site": "npx wrangler deploy",
    "deploy:app": "npx wrangler deploy -c wrangler.app.toml",
    "check:scenarios": "npx tsx src/scripts/check-scenarios.ts",
    "migrate:concepts": "npx tsx src/scripts/migrate_v1_to_v2.ts",
    "build:catalog": "node scripts/extract_catalog.js && node scripts/build_teacher_catalog.js && node scripts/build_chapter_pathways.js && node scripts/build_diamonds_onepager.js",
    "smoke": "playwright test",
    "smoke:install": "playwright install chromium",
    "smoke:visual-validator": "npx tsx --env-file=.env.local src/scripts/smoke_visual_validator.ts",
    "visual:eyes": "npx tsx --env-file=.env.local src/scripts/visual_eyes.ts",
    "visual:approve": "npx tsx --env-file=.env.local src/scripts/visual_approve.ts",
    "log:lesson": "npx tsx --env-file=.env.local src/scripts/log_lesson.ts",
    "prewarm:deepdive": "npx tsx --env-file=.env.local src/scripts/prewarm_deepdive.ts",
    "solve:layout": "npx tsx --env-file=.env.local src/scripts/solve_layout.ts",
    "sync:agents": "node scripts/sync-agents.js",
    "check:agents": "node scripts/sync-agents.js --check",
    "test": "vitest run",
    "build:pilot": "npx tsx src/scripts/build_review_site.ts --pilot"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/google": "^3.0.31",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "@lume/kiwi": "^0.4.4",
    "@sparticuz/chromium": "^148.0.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "@types/katex": "^0.16.8",
    "ai": "^6.0.98",
    "dotenv": "^17.3.1",
    "katex": "^0.16.33",
    "lucide-react": "^0.575.0",
    "mathjs": "^15.2.0",
    "next": "16.1.6",
    "pdf-parse": "^1.1.4",
    "pixelmatch": "^7.2.0",
    "plotly.js": "^3.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-plotly.js": "^2.6.0",
    "react-resizable-panels": "^2.1.9",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "music-metadata": "^11.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
