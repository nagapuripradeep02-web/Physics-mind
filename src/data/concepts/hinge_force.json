          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "If the hinge could only push vertically, nothing would balance the horizontal load. The whole system would slide sideways."
              },
              {
                "id": "s2",
                "text_en": "The horizontal component of the hinge force balances any horizontal load in the problem."
              },
              {
