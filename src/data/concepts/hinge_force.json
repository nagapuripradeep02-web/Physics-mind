                "position": {
                  "x": 155,
                  "y": 130
                }
              },
              {
                "type": "annotation",
                "text": "Normal reaction and string\neach act along ONE fixed direction.",
                "position": {
                  "x": 30,
                  "y": 220
                }
              }
            ],
            "right_scene": [
              {
                "type": "body",
                "id": "hinge_symbol",
