            {
              "id": "s2",
              "text_en": "Horizontal equilibrium gives H equals zero. There is nothing horizontal to balance."
            },
            {
              "id": "s3",
              "text_en": "Vertical equilibrium gives V equals W, just forty newtons upward."
            },
            {
              "id": "s4",
              "text_en": "The hinge force becomes purely vertical in this case. That is the limit everyone starts with, but it is only a special case."
            }
          ]
