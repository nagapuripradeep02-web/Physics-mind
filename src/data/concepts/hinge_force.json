        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "A heavy door hangs from just two small pins in the wall."
            },
            {
              "id": "s2",
              "text_en": "The door weighs one hundred ninety six newtons. Gravity pulls it straight down."
            },
            {
              "id": "s3",
              "text_en": "The hinge must be pushing back on the door, otherwise it would fall."
            },
            {
              "id": "s4",
              "text_en": "But in which direction does the hinge force point? That is the question we answer today."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
      "STATE_2": {
        "title": "Hinge Is Different — It Can Push or Pull in ANY Direction",
        "duration": 7,
        "scene_composition": [
          {
            "type": "comparison_panel",
            "id": "string_vs_hinge",
            "left_label": "String or Normal — one direction only",
            "right_label": "Hinge — any direction, push OR pull",
            "left_scene": [
              {
                "type": "body",
                "shape": "rect",
                "label": "String can only pull along its length",
                "fill_color": "#6B7280",
                "position": {
