                  "x": 140,
                  "y": 140
                },
                "size": 24
              },
              {
                "type": "force_arrow",
                "magnitude": 15,
                "direction_deg": 53,
                "label": "F_hinge (any angle)",
                "color": "#8B5CF6",
                "scale_pixels_per_unit": 3,
                "position": {
                  "x": 140,
                  "y": 140
                }
              },
              {
                "type": "annotation",
                "text": "A hinge can push or pull\nin whatever direction\nequilibrium demands.",
                "color": "#8B5CF6",
                "position": {
                  "x": 30,
                  "y": 220
                }
              }
            ]
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "There are three common types of constraints — strings, normal reactions, and hinges."
            },
            {
              "id": "s2",
              "text_en": "A string can only pull, and only along its own length."
            },
            {
              "id": "s3",
              "text_en": "A normal reaction can only push, and only perpendicular to the contact surface."
            },
            {
              "id": "s4",
              "text_en": "A hinge is different. It can exert a force in any direction — push or pull, as long as equilibrium needs it."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
      "STATE_3": {
        "title": "How to Find Hinge Force — Equilibrium Equations",
        "duration": 7,
        "scene_composition": [
          {
            "type": "surface",
            "id": "wall",
            "orientation": "vertical",
            "position": {
              "x": 130,
              "y": 120
            },
            "length": 300,
            "texture": "wall"
          },
          {
            "type": "body",
            "id": "hinge_point",
            "shape": "circle",
            "label": "Hinge",
            "label_below": true,
            "position": {
              "x": 175,
              "y": 270
            },
            "size": 16,
            "fill_color": "#374151"
          },
          {
            "type": "body",
            "id": "rod",
            "shape": "rect",
            "label": "Rod (W = 40 N)",
            "position": {
              "x": 200,
              "y": 260
            },
            "size": {
              "w": 280,
              "h": 18
            },
            "fill_color": "#92400E"
          },
          {
            "type": "force_arrow",
            "from": {
              "x": 470,
              "y": 269
            },
            "magnitude_expr": "F_ext",
            "direction_deg": 270,
            "label_expr": "F_ext = {F_ext} N (external load)",
            "color": "#EF4444",
            "scale_pixels_per_unit": 2
          },
          {
            "type": "force_arrow",
            "from": {
              "x": 330,
              "y": 269
            },
            "magnitude_expr": "W",
            "direction_deg": 270,
            "label_expr": "W = {W} N (weight at center)",
            "color": "#B91C1C",
            "scale_pixels_per_unit": 2
          },
          {
            "type": "force_arrow",
            "id": "H_dashed",
            "from": {
              "x": 175,
              "y": 269
            },
            "magnitude_expr": "F_ext",
            "direction_deg": 0,
            "label_expr": "H = {F_ext} N",
            "color": "#3B82F6",
            "style": "dashed",
            "scale_pixels_per_unit": 2
          },
          {
            "type": "force_arrow",
            "id": "V_dashed",
            "from": {
              "x": 175,
              "y": 269
            },
            "magnitude_expr": "W",
            "direction_deg": 90,
            "label_expr": "V = {W} N",
            "color": "#10B981",
            "style": "dashed",
            "scale_pixels_per_unit": 2
          },
          {
            "type": "force_arrow",
            "id": "F_hinge_resultant",
            "from": {
              "x": 175,
              "y": 269
            },
            "magnitude_expr": "Math.sqrt(F_ext*F_ext + W*W)",
            "direction_deg_expr": "Math.atan2(W, F_ext) * 180 / Math.PI",
            "label_expr": "F_hinge = {Math.sqrt(F_ext*F_ext + W*W).toFixed(1)} N",
            "color": "#8B5CF6",
            "style": "solid",
            "line_width": 3,
            "scale_pixels_per_unit": 2
          },
          {
            "type": "formula_box",
            "equation_expr": "ΣFx = 0 → H = {F_ext} N    ΣFy = 0 → V = {W} N    F_hinge = √(H² + V²) = {Math.sqrt(F_ext*F_ext + W*W).toFixed(1)} N",
            "position": {
              "x": 60,
              "y": 440
            },
            "border_color": "#8B5CF6"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "The method has two steps. First, split the hinge force into a horizontal component H and a vertical component V."
            },
            {
              "id": "s2",
              "text_en": "Use horizontal equilibrium. Sum of forces in x equals zero. That gives you H."
            },
            {
              "id": "s3",
              "text_en": "Use vertical equilibrium. Sum of forces in y equals zero. That gives you V."
            },
            {
              "id": "s4",
              "text_en": "Combine with Pythagoras. F equals the square root of H squared plus V squared. The angle is arctan of V over H."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
