{
  "concept_id": "hinge_force",
  "concept_name": "Hinge Force",
  "chapter": 8,
  "section": "8.1",
  "renderer_pair": {
    "panel_a": "mechanics_2d",
    "panel_b": "graph_interactive"
  },
  "real_world_anchor": {
    "primary": "A heavy door hangs from two small hinges. Those hinges must be pushing on the door — but in which direction?",
    "secondary": "A gate swings on its pin joint. The gate experiences a horizontal pull when you push it and a vertical pull from gravity. The hinge absorbs both.",
    "tertiary": "A rod pinned to a wall with a load hanging at the free end. The pin has to react somehow — where does its force point?"
  },
  "physics_engine_config": {
    "formulas": {
      "hinge_horizontal": "H = ΣFx (equilibrium in x direction)",
      "hinge_vertical": "V = ΣFy (equilibrium in y direction)",
      "hinge_magnitude": "F_hinge = sqrt(H^2 + V^2)",
      "hinge_angle": "theta = atan2(V, H)"
    },
    "variables": {
      "W": {
        "name": "Weight of rod",
        "unit": "N",
        "min": 10,
        "max": 100,
        "default": 40
      },
      "F_ext": {
        "name": "External load",
        "unit": "N",
        "min": 0,
        "max": 80,
        "default": 30
      },
      "H": {
        "name": "Horizontal component of hinge force",
        "unit": "N",
        "derived": "F_ext"
      },
      "V": {
        "name": "Vertical component of hinge force",
        "unit": "N",
        "derived": "W"
      },
      "F_hinge": {
        "name": "Total hinge force",
        "unit": "N",
        "derived": "sqrt(H*H + V*V)"
      }
    },
    "constraints": [
      "Hinge constrains position — cannot constrain rotation",
      "Hinge force can be in ANY direction in the plane (unlike N which is perpendicular, unlike T which is a pull)",
      "Find H and V from equilibrium: ΣFx = 0, ΣFy = 0",
      "Magnitude: F_hinge = √(H² + V²)",
      "Hinge can both push and pull — it is a pin joint"
    ]
  },
