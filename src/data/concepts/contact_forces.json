  "epic_c_branches": [
    {
      "branch_id": "N_is_always_vertical",
      "misconception": "The normal reaction always points straight up.",
      "trigger_phrases": [
        "N is always upward",
        "normal force is always vertical",
        "N points up"
      ],
      "state_sequence": [
        "EPIC_C_1",
        "EPIC_C_2"
      ],
      "states": {
        "EPIC_C_1": {
          "title": "Your Belief: N Is Always Upward",
          "scene_composition": [
            {
              "type": "comparison_panel",
              "left_label": "Flat floor — N is vertical (true)",
              "right_label": "Wall — N is horizontal (belief breaks)",
              "left_scene": [
                {
                  "type": "force_arrow",
                  "magnitude": 20,
                  "direction_deg": 90,
                  "label": "N (perpendicular to floor)",
                  "color": "#10B981",
                  "position": {
                    "x": 140,
                    "y": 190
                  },
                  "scale_pixels_per_unit": 3
                }
              ],
              "right_scene": [
                {
                  "type": "force_arrow",
                  "magnitude": 20,
                  "direction_deg": 0,
                  "label": "N (perpendicular to wall, horizontal)",
                  "color": "#10B981",
                  "position": {
                    "x": 140,
                    "y": 190
                  },
                  "scale_pixels_per_unit": 3
                },
                {
                  "type": "annotation",
                  "text": "The wall gives N horizontally — not upward!",
                  "color": "#EF4444",
                  "position": {
                    "x": 40,
                    "y": 240
                  }
                }
              ]
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "On a flat floor, N does point upward. That part is true. But the rule is not that N is always up."
              },
              {
                "id": "s2",
                "text_en": "The real rule is simple: N is always perpendicular to the contact surface."
              },
              {
                "id": "s3",
                "text_en": "For a wall, the contact surface is vertical, so N must point horizontally."
              },
              {
                "id": "s4",
                "text_en": "Tilt the surface and N tilts with it. N follows the surface, not gravity."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        },
        "EPIC_C_2": {
          "title": "N Is Always Perpendicular — An Incline Proves It",
          "scene_composition": [
            {
              "type": "surface",
              "id": "incline",
              "orientation": "inclined",
              "angle_deg": 30,
              "position": {
                "x": 180,
                "y": 400
              },
              "length": 300,
              "texture": "smooth"
            },
            {
              "type": "body",
              "id": "block",
              "shape": "rect",
