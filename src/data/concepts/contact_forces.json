            "step": 1,
            "default": 15,
            "label": "Friction f (N)"
          },
          {
            "type": "formula_box",
            "equation_expr": "F = √({N}² + {f}²) = {sqrt(N*N + f*f).toFixed(1)} N",
            "position": {
              "x": 475,
              "y": 220
            },
            "border_color": "#EF4444"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Now use the sliders. Vary N and f and watch the resultant F build itself."
            },
            {
              "id": "s2",
              "text_en": "Notice that F is always larger than each piece alone — the closed triangle on the canvas shows you why."
            },
            {
              "id": "s3",
              "text_en": "Drag friction to zero. F collapses onto N. That is the smooth surface limit."
            },
            {
              "id": "s4",
              "text_en": "This triangle is the geometry of every contact problem you will ever solve."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      }
    }
  },
