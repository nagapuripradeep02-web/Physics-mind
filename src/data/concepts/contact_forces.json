{
  "concept_id": "contact_forces",
  "concept_name": "Contact Forces",
  "chapter": 8,
  "section": "8.1",
  "renderer_pair": {
    "panel_a": "mechanics_2d",
    "panel_b": "graph_interactive"
  },
  "real_world_anchor": {
    "primary": "A wooden crate dragged across a concrete floor — the floor pushes up (normal reaction) and also drags backwards on the crate (friction). One contact, two forces.",
    "secondary": "Pushing a cart through a market — the handle is in contact with your hand. Your hand pushes the cart forward; the cart pushes back on your hand (normal reaction) and your skin grips the handle (friction).",
    "tertiary": "A shoe sole pressed against the road — the road pushes the sole upward (normal reaction) and resists sliding (friction). Walking is impossible without both."
  },
  "physics_engine_config": {
    "formulas": {
      "contact_force": "F = sqrt(N^2 + f^2)",
      "normal_reaction": "N = perpendicular to surface",
      "friction": "f = parallel to surface, opposing motion"
    },
    "variables": {
      "N": {
        "name": "Normal Reaction",
        "unit": "N",
        "min": 0,
        "max": 100,
        "default": 20
      },
      "f": {
        "name": "Friction Force",
        "unit": "N",
        "min": 0,
        "max": 100,
        "default": 15
      },
      "F": {
        "name": "Total Contact Force",
        "unit": "N",
        "derived": "sqrt(N*N + f*f)"
      },
      "theta": {
        "name": "Angle of F with N",
        "unit": "degrees",
        "derived": "atan2(f, N) * 180/PI"
      }
    },
    "constraints": [
      "N is always perpendicular to contact surface",
      "f is always parallel to contact surface",
      "N and f are always mutually perpendicular",
      "F = sqrt(N^2 + f^2) — Pythagoras theorem",
      "Smooth surface: f = 0, F = N"
    ]
  },
  "epic_l_path": {
    "state_count": 6,
    "states": {
      "STATE_1": {
        "title": "Two Blocks in Contact — What Lives at the Surface?",
        "duration": 5,
        "scene_composition": [
          {
            "type": "body",
            "id": "block_A",
            "shape": "rect",
            "label": "Block A",
            "position": {
              "x": 240,
              "y": 260
            },
            "size": {
              "w": 110,
              "h": 110
            },
            "fill_color": "#3B82F6"
          },
          {
            "type": "body",
            "id": "block_B",
            "shape": "rect",
            "label": "Block B",
            "position": {
              "x": 410,
              "y": 260
            },
            "size": {
              "w": 110,
              "h": 110
            },
            "fill_color": "#F59E0B"
          },
          {
            "type": "label",
            "text": "?",
            "position": {
              "x": 385,
              "y": 265
            },
            "font_size": 56,
            "color": "#EF4444",
            "bold": true
          },
          {
            "type": "annotation",
            "text": "The blocks touch.\nWhat forces live at\nthis contact line?",
            "position": {
              "x": 600,
              "y": 160
            },
            "style": "callout"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Two blocks sit against each other. Their surfaces are in contact."
            },
            {
              "id": "s2",
              "text_en": "If you push one block, the other pushes back. Something is happening at the contact line."
            },
            {
              "id": "s3",
              "text_en": "There must be a force — without one, nothing could resist the push."
            },
            {
              "id": "s4",
              "text_en": "Today we will zoom in and find out exactly which forces emerge from that contact."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
      "STATE_2": {
        "title": "Zoom In — Two Forces Emerge from the Contact",
        "duration": 7,
        "scene_composition": [
          {
            "type": "surface",
            "id": "floor",
            "orientation": "horizontal",
            "position": {
              "x": 120,
              "y": 400
            },
            "length": 420,
            "texture": "rough",
            "label": "Contact surface"
          },
          {
            "type": "body",
            "id": "block",
            "shape": "rect",
            "label": "Block",
            "attach_to_surface": {
              "surface_id": "floor",
              "position_fraction": 0.5
            },
            "size": {
              "w": 140,
              "h": 110
            },
            "fill_color": "#3B82F6"
          },
          {
            "type": "force_arrow",
            "id": "N_arrow",
            "from": "block_bottom_center",
            "magnitude": 20,
            "direction_deg": 90,
            "label": "N (Normal Reaction)",
            "color": "#10B981",
            "scale_pixels_per_unit": 4
          },
          {
            "type": "force_arrow",
            "id": "f_arrow",
            "from": "block_bottom_center",
            "magnitude": 15,
            "direction_deg": 180,
            "label": "f (Friction)",
            "color": "#F59E0B",
            "scale_pixels_per_unit": 4
          },
          {
            "type": "angle_arc",
            "center": {
              "x": 330,
              "y": 400
            },
            "from_deg": 90,
            "to_deg": 180,
            "radius": 32,
            "label": "90°",
            "color": "#EF4444"
          },
          {
            "type": "annotation",
            "text": "N is perpendicular\nto the surface.\n\nf is parallel\nto the surface.\n\nThey meet at 90°.",
            "position": {
              "x": 600,
              "y": 180
            },
            "style": "callout"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Zoom into the contact surface. Exactly two forces emerge from it."
            },
            {
              "id": "s2",
              "text_en": "The first force points straight out of the surface. We call it the normal reaction, written N."
            },
            {
              "id": "s3",
              "text_en": "The second force lies flat along the surface and opposes any sliding. We call it friction, written f."
            },
            {
              "id": "s4",
              "text_en": "N and f always meet at a right angle. They never overlap."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
      "STATE_3": {
        "title": "Why Perpendicular? Why Parallel? The Geometry",
        "duration": 7,
        "scene_composition": [
          {
            "type": "surface",
            "id": "floor",
            "orientation": "horizontal",
            "position": {
              "x": 120,
              "y": 400
            },
            "length": 420,
            "texture": "rough"
          },
          {
            "type": "body",
            "id": "block_on_surface",
            "shape": "rect",
            "label": "Block",
            "attach_to_surface": {
              "surface_id": "floor",
              "position_fraction": 0.4
            },
            "size": {
              "w": 120,
              "h": 100
            },
            "fill_color": "#3B82F6"
          },
          {
            "type": "force_arrow",
            "id": "N_arrow",
            "from": "block_bottom_center",
            "magnitude": 20,
            "direction_deg": 90,
            "label": "N",
            "color": "#10B981",
            "scale_pixels_per_unit": 4
          },
          {
            "type": "force_arrow",
            "id": "f_arrow",
            "from": "block_bottom_center",
            "magnitude": 15,
            "direction_deg": 180,
            "label": "f",
            "color": "#F59E0B",
            "scale_pixels_per_unit": 4
          },
          {
            "type": "annotation",
            "id": "N_reason",
            "text": "N: A surface can only PUSH outward.\nIt cannot pull you inward.\nSo N must be perpendicular.",
            "position": {
              "x": 600,
              "y": 160
            },
            "style": "callout",
            "color": "#10B981"
          },
          {
            "type": "annotation",
            "id": "f_reason",
            "text": "f: Sliding happens ALONG the surface.\nFriction resists that sliding,\nso f must lie along the surface.",
            "position": {
              "x": 600,
              "y": 320
            },
            "style": "callout",
            "color": "#F59E0B"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Why must N be perpendicular? Because a surface can only push outward — it cannot pull you inward."
            },
            {
              "id": "s2",
              "text_en": "A table pushes you upward. It never yanks you down. Only perpendicular push is possible."
            },
            {
              "id": "s3",
              "text_en": "Why must f be parallel? Because sliding happens along the surface, and friction always resists that sliding."
            },
            {
              "id": "s4",
              "text_en": "So N perpendicular and f parallel is not a coincidence — it is forced by the geometry of contact itself."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
      "STATE_4": {
        "title": "Combine Them — The Resultant Contact Force",
        "duration": 6,
        "scene_composition": [
          {
            "type": "body",
            "id": "block",
            "shape": "rect",
            "label": "Block",
            "position": {
              "x": 280,
              "y": 300
            },
            "size": {
              "w": 110,
              "h": 100
            },
            "fill_color": "#6B7280"
          },
          {
            "type": "force_arrow",
            "id": "N_component",
            "from": {
              "x": 335,
              "y": 400
            },
            "to": {
              "x": 335,
              "y": 300
            },
            "label": "N = 20 N",
            "color": "#10B981",
            "style": "dashed"
          },
          {
            "type": "force_arrow",
            "id": "f_component",
            "from": {
              "x": 335,
              "y": 400
            },
            "to": {
              "x": 455,
              "y": 400
            },
            "label": "f = 15 N",
            "color": "#F59E0B",
            "style": "dashed"
          },
          {
            "type": "force_arrow",
            "id": "F_resultant",
            "from": {
              "x": 335,
              "y": 400
            },
            "to": {
              "x": 455,
              "y": 300
            },
            "label": "F = 25 N",
            "color": "#EF4444",
            "style": "solid",
            "line_width": 3
          },
          {
            "type": "angle_arc",
            "center": {
              "x": 335,
              "y": 400
            },
            "from_deg": 0,
            "to_deg": 40,
            "radius": 48,
            "label": "θ = 37°",
            "color": "#F97316"
          },
          {
            "type": "formula_box",
            "equation": "F = √(N² + f²) = √(20² + 15²) = √625 = 25 N",
            "position": {
              "x": 475,
              "y": 260
            },
            "border_color": "#EF4444"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "N and f sit at ninety degrees to each other, so Pythagoras applies directly."
            },
            {
              "id": "s2",
              "text_en": "The total contact force F equals the square root of N squared plus f squared."
            },
            {
              "id": "s3",
              "text_en": "Plug in twenty newtons for N and fifteen newtons for f. The resultant is twenty five newtons, at roughly thirty seven degrees from the surface normal."
            },
            {
              "id": "s4",
              "text_en": "This formula holds for every contact — smooth or rough, flat or inclined. Always."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
