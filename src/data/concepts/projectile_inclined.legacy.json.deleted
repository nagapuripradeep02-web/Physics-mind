    ]
  },
  "jee_specific": {
    "trap_1": "Standard formulas (R=u²sin2θ/g) don't work on inclined plane. Most common JEE mistake in this topic.",
    "trap_2": "θ is always measured from HORIZONTAL in DC Pandey's convention — not from the slope. Angle from slope = (θ-α).",
    "trap_3": "Maximum range angle is 45°+α/2 from horizontal, which equals (90°-α)/2 from the slope surface.",
    "trap_4": "For down-the-slope launch, gravity component along slope ADDS to motion — T and R both increase. Students often apply up-slope formula.",
    "trap_5": "The condition 'ball lands on slope' means sy=0 in tilted frame, NOT sy=0 in lab frame."
  },
  "concept_relationships": {
    "prerequisites": [
      "projectile_motion",
