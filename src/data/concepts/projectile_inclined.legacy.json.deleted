      "uniform_acceleration"
    ],
    "leads_to": [
      "relative_motion_projectiles"
    ],
    "common_confusion_with": [
      "projectile_motion — students apply flat-ground formulas here"
    ]
  },
  "regeneration_variants": [
    {
      "variant_id": 1,
      "scenario_type": "projectile_inclined",
      "approach": "lab_frame_direct",
      "entry_state": "STATE_1",
      "teacher_angle": "Stay in the lab frame (horizontal x, vertical y). Set up when ball lands ON slope: condition is y = x·tanα. Substitute into trajectory equation and solve. No axis tilting needed — but more algebra.",
      "locked_facts_focus": [
        "fact_9",
        "fact_1",
        "fact_4"
      ],
      "panel_b_focus": "Show both frames side by side — lab frame algebra vs tilted frame method reaching same answer."
    },
    {
      "variant_id": 2,
      "scenario_type": "projectile_inclined",
      "approach": "max_range_first",
      "entry_state": "STATE_4",
      "teacher_angle": "Start with the maximum range result θ_max = 45°+α/2. Show WHY: the angle that bisects the angle between vertical and slope normal. Derive T and R formulas from there.",
      "locked_facts_focus": [
        "fact_5",
        "fact_6",
        "fact_3"
      ],
      "panel_b_focus": "R vs θ curve with maximum highlighted as primary focus from STATE_1."
    }
  ],
  "panel_b_config": {
    "renderer": "graph_interactive",
    "pvl_colors": {
      "background": "#0f172a",
      "grid": "#1e293b",
      "axis": "#94a3b8",
      "highlight": "#fbbf24"
    },
    "x_axis": { "label": "Launch angle", "symbol": "α", "unit": "°", "min": 0, "max": 90 },
    "y_axis": { "label": "Range on incline", "symbol": "R", "unit": "m", "min": 0, "max": 60 },
    "lines": [
      { "id": "range_vs_angle", "formula": "(2 * 20 * 20 * Math.sin(x * Math.PI / 180) * Math.cos((x + 30) * Math.PI / 180)) / (9.8 * Math.cos(30 * Math.PI / 180) * Math.cos(30 * Math.PI / 180))", "color": "#f97316", "label": "Range vs launch angle (incline 30°)" },
      { "id": "flat_ref", "formula": "(20 * 20 * Math.sin(2 * x * Math.PI / 180)) / 9.8", "color": "#94a3b8", "dash": "dash", "label": "Flat ground range (reference)" }
    ],
    "sliders": [
      { "id": "alpha", "label": "Launch angle α (degrees)", "min": 0, "max": 90, "default": 30 }
    ],
    "legend": [
      { "id": "range_vs_angle", "label": "Incline range" },
      { "id": "flat_ref", "label": "Flat ref" }
    ],
    "states": {
      "STATE_1": { "active_lines": [], "show_sliders": false, "highlight_point": false },
      "STATE_2": { "active_lines": ["flat_ref"], "show_sliders": false, "highlight_point": false },
      "STATE_3": { "active_lines": ["flat_ref", "range_vs_angle"], "show_sliders": false, "highlight_point": false },
      "STATE_4": { "active_lines": ["range_vs_angle"], "show_sliders": false, "highlight_point": true, "point_x": 30, "point_y": 35, "label": "Optimal angle shifts on incline" },
      "STATE_5": { "active_lines": ["flat_ref", "range_vs_angle"], "show_sliders": false, "highlight_point": true, "point_x": 30, "point_y": 35, "label": "Incline reduces range vs flat" },
      "STATE_6": { "active_lines": ["flat_ref", "range_vs_angle"], "show_sliders": true, "highlight_point": true, "point_x": 30, "point_y": 35 }
    }
  }
}
