    "panel_b": "plotly — R vs θ curve for the given α, showing maximum at 45°+α/2. Updates as α changes.",
    "sync_event": "Moving α slider in Panel A shifts the entire R-vs-θ curve and maximum marker in Panel B",
    "bidirectional": true,
    "sync_trigger": "alpha_change"
  },
