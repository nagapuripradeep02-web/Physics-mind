  "panel_b_config": {
    "renderer": "graph_interactive",
    "pvl_colors": {
      "background": "#0f172a",
      "grid": "#1e293b",
      "axis": "#94a3b8",
      "highlight": "#fbbf24"
    },
    "x_axis": { "label": "Time", "symbol": "t", "unit": "s", "min": 0, "max": 5 },
    "y_axis": { "label": "Relative vertical position", "symbol": "Δy", "unit": "m", "min": -30, "max": 30 },
    "lines": [
      { "id": "delta_y", "formula": "(15 - 10) * x - 0.5 * 9.8 * x * x + 0.5 * 9.8 * x * x", "color": "#60a5fa", "label": "Δy = (uy1 - uy2)·t — gravity cancels" },
      { "id": "delta_y_linear", "slope": 5, "intercept": 0, "color": "#60a5fa", "label": "Δy = (uy1 - uy2)·t — straight line" },
      { "id": "zero_ref", "slope": 0, "intercept": 0, "color": "#ef4444", "dash": "dash", "label": "Δy = 0 — collision line" }
    ],
    "sliders": [],
