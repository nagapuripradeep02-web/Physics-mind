    "competitive": {
      "assessment_style": "shortcut_plus_edge_case",
      "shortcuts": [
        {
          "trigger": "frictionless surface, single force",
          "formula": "a = F/m, direction along F",
          "when": "Smooth horizontal surface, one external F. Skip the full FBD if it's clearly unbalanced and friction is given as zero — go direct to a = F/m."
        },
        {
          "trigger": "force at angle to horizontal",
          "formula": "a_x = F cos θ / m, a_y = F sin θ / m",
          "when": "When F has a vertical component, a is also tilted. Don't assume motion stays along the floor — check if F_y > 0 changes contact (block could lift)."
        },
        {
          "trigger": "find v after time t (from rest)",
          "formula": "v = (F/m) · t",
          "when": "Combine Newton II and kinematics in one step. Skip computing a separately."
        },
        {
          "trigger": "two forces, same direction",
          "formula": "a = (F_1 + F_2) / m",
          "when": "Net force is the sum (vector sum if not collinear). a always uses NET F, never one of the individual forces."
        }
      ],
      "edge_cases": [
        {
          "boundary": "F = 0 (no force)",
          "behavior": "a = 0. Block continues at whatever v it already had (Newton I as a special case)."
        },
        {
          "boundary": "F applied but body has friction",
          "behavior": "Net F = F_applied - friction. a = (F_applied - friction)/m. Use NET force, not just applied."
        },
        {
          "boundary": "F vertical upward, F > mg",
          "behavior": "Block lifts off the surface. Normal becomes zero. Net F vertically = F - mg upward."
        },
        {
          "boundary": "F vertical upward, F < mg",
          "behavior": "Block stays on surface. Vertical net F = 0 (N adjusts). Horizontal net F = 0 (assuming F purely vertical). So a = 0. Block does not lift, does not move."
        },
        {
          "boundary": "v initial non-zero, F perpendicular to v",
          "behavior": "v_perp grows from a, v_parallel unchanged. Trajectory curves (this is projectile motion when F = gravity)."
        }
      ]
    }
  }
