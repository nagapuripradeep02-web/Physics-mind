  "epic_c_branches": [
    {
      "branch_id": "stationary_means_no_force",
      "misconception": "If a body is at rest, no force acts on it (or no net force CAN act on it)",
      "trigger_phrases": [
        "block is stationary so no force",
        "if it's not moving force is zero",
        "no movement no force",
        "stationary block has no F",
        "F must be zero if a is zero"
      ],
      "states": {
        "STATE_1": {
          "title": "The Wrong Belief — Rest Means No Force",
          "duration": 9,
          "teaching_method": "misconception_confrontation",
          "advance_mode": "auto_after_tts",
          "focal_primitive_id": "myth_label",
          "scene_composition": [
            {
              "type": "annotation",
              "id": "myth_label",
              "text": "MYTH: Stationary block ⇒ zero force on it",
              "position": { "x": 380, "y": 100 },
              "style": "callout",
              "color": "#EF4444"
            },
            {
              "type": "body",
              "id": "book",
              "shape": "rectangle",
              "position": { "x": 380, "y": 280 },
              "size": { "w": 80, "h": 30 },
              "color": "#9CA3AF"
            },
            {
              "type": "annotation",
              "id": "book_label",
              "text": "Book on table — not moving",
              "position": { "x": 380, "y": 250 },
              "font_size": 12,
              "color": "#9CA3AF"
            },
            {
              "type": "annotation",
              "id": "diagnosis",
              "text": "Two forces act on the book:\n  weight mg downward\n  normal N upward\nThey balance. Net force = 0.\nBut individual forces are NOT zero.",
              "position": { "x": 380, "y": 410 },
              "font_size": 13,
              "color": "#FCD34D"
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              { "id": "s1", "text_en": "A common mistake — students see a stationary book and conclude no force acts on it." },
              { "id": "s2", "text_en": "But weight is pulling it down, and the table is pushing it up. Two real, non-zero forces." },
              { "id": "s3", "text_en": "They cancel. Net force is zero, so acceleration is zero, so the book stays at rest. That is what Newton's second law predicts. It does NOT say there are no forces." }
            ]
          }
        }
      }
    },
    {
      "branch_id": "velocity_equals_force",
      "misconception": "Velocity points where the force points",
      "trigger_phrases": [
        "velocity equals force direction",
        "v points along F",
        "if I push right block moves right immediately",
        "force makes velocity",
        "F gives v"
      ],
      "states": {
        "STATE_1": {
          "title": "The Wrong Belief — v Follows F Directly",
          "duration": 9,
          "teaching_method": "misconception_confrontation",
          "advance_mode": "auto_after_tts",
          "focal_primitive_id": "myth_label",
          "scene_composition": [
            {
              "type": "annotation",
              "id": "myth_label",
              "text": "MYTH: v points where F points",
              "position": { "x": 380, "y": 100 },
              "style": "callout",
              "color": "#EF4444"
            },
            {
              "type": "animated_path",
              "id": "wrong_v",
              "from": { "x": 250, "y": 280 },
              "to": { "x": 450, "y": 280 },
              "easing": "ease_out",
              "duration_ms": 800,
              "head_first": true,
              "color": "#EF4444",
              "line_weight": 3,
              "arrow_head": true,
              "label": "wrong: v follows F instantly",
              "appear_at_ms": 1500,
              "animate_in_ms": 800
            },
            {
              "type": "annotation",
              "id": "diagnosis_v",
              "text": "F = m·a, NOT F = m·v.\nF gives ACCELERATION (rate of change of v).\nv builds up over time from a.\nA pendulum at the bottom has v ≠ 0 even when net F = 0 momentarily.",
              "position": { "x": 380, "y": 420 },
              "font_size": 13,
              "color": "#FCD34D"
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              { "id": "s1", "text_en": "Students often write F equals m v. That is wrong." },
              { "id": "s2", "text_en": "Newton's second law is F equals m a. Force gives acceleration, not velocity." },
              { "id": "s3", "text_en": "Velocity is what acceleration builds up over time. A pendulum swinging through the lowest point has zero net force but maximum velocity. Velocity and force are different quantities." }
            ]
          }
        }
      }
    },
    {
      "branch_id": "more_mass_more_force_needed",
      "misconception": "Heavier objects need more force to exist or to stay still — confusing force with weight in dynamics",
      "trigger_phrases": [
        "heavy block needs more F",
        "more mass means more force",
        "double mass double F",
        "mass requires force",
        "weight equals force needed to push"
      ],
      "states": {
        "STATE_1": {
          "title": "The Wrong Belief — Mass Demands Force",
          "duration": 9,
          "teaching_method": "misconception_confrontation",
          "advance_mode": "auto_after_tts",
          "focal_primitive_id": "myth_label",
          "scene_composition": [
            {
              "type": "annotation",
              "id": "myth_label",
              "text": "MYTH: Heavier ⇒ more force needed (just to be there)",
              "position": { "x": 380, "y": 100 },
              "style": "callout",
              "color": "#EF4444"
            },
            {
              "type": "body",
              "id": "light_block",
              "shape": "rectangle",
              "position": { "x": 250, "y": 290 },
              "size": { "w": 50, "h": 40 },
              "color": "#60A5FA"
            },
            {
              "type": "annotation",
              "id": "light_label",
              "text": "1 kg",
              "position": { "x": 250, "y": 340 },
              "font_size": 12,
              "color": "#60A5FA"
            },
            {
              "type": "body",
              "id": "heavy_block",
              "shape": "rectangle",
              "position": { "x": 480, "y": 280 },
              "size": { "w": 80, "h": 60 },
              "color": "#60A5FA"
            },
            {
              "type": "annotation",
              "id": "heavy_label",
              "text": "10 kg",
              "position": { "x": 480, "y": 350 },
              "font_size": 12,
              "color": "#60A5FA"
            },
            {
              "type": "annotation",
              "id": "diagnosis_mass",
              "text": "Same F = 10 N applied to both:\n  light: a = 10 m/s² (jumps fast)\n  heavy: a = 1 m/s² (creeps)\nBoth ACCELERATE. Mass scales the response, not the requirement.\nF is needed to ACCELERATE, not to push back gravity.",
              "position": { "x": 380, "y": 430 },
              "font_size": 13,
              "color": "#FCD34D"
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              { "id": "s1", "text_en": "Students confuse weight with the force-needed-to-push. They aren't the same." },
              { "id": "s2", "text_en": "Apply the same ten newton force to a one kilogram block and a ten kilogram block. Both will accelerate. The light one accelerates fast, the heavy one slow." },
              { "id": "s3", "text_en": "Mass scales the acceleration response — it doesn't gate the existence of motion. Even one newton on a one ton truck causes acceleration. Tiny acceleration, but non-zero." }
            ]
          }
        }
      }
    },
    {
      "branch_id": "f_equals_mv_formula_confusion",
      "misconception": "Writing F = m·v instead of F = m·a (formula slip with deep conceptual cost)",
      "trigger_phrases": [
        "F equals mv",
        "F = m times v",
        "force equals mass times velocity",
        "is it F = mv",
        "newton second law is F = mv"
      ],
      "states": {
        "STATE_1": {
          "title": "The Wrong Formula — F = m·v is Momentum, Not Newton II",
          "duration": 10,
          "teaching_method": "misconception_confrontation",
          "advance_mode": "auto_after_tts",
          "focal_primitive_id": "myth_label",
          "scene_composition": [
            {
              "type": "annotation",
              "id": "myth_label",
              "text": "MYTH: Newton II says F = m·v",
              "position": { "x": 380, "y": 100 },
              "style": "callout",
              "color": "#EF4444"
            },
            {
              "type": "annotation",
              "id": "dimensional_check",
              "text": "Dimensions: [F] = M·L·T⁻²\n[m·v] = M·L·T⁻¹  ✗\n[m·a] = M·L·T⁻²  ✓\n\nOnly m·a has the dimensions of force.",
              "position": { "x": 600, "y": 220 },
              "style": "formula_box",
              "color": "#EF4444"
            },
            {
              "type": "annotation",
              "id": "diagnosis_formula",
              "text": "m · v has a name: it's MOMENTUM (p).\np = m·v.\nNewton's second law in fact says:\nF = dp/dt   (rate of change of momentum)\nWhen m is constant, dp/dt = m · dv/dt = m · a.\nThat's how F = m·a comes from F = dp/dt.\nF = m·v is dimensionally and physically wrong.",
              "position": { "x": 280, "y": 320 },
              "style": "formula_box",
              "color": "#FCD34D"
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              { "id": "s1", "text_en": "F equals m v is a common slip. m v is not a force — it's momentum." },
              { "id": "s2", "text_en": "Newton's second law says force equals rate of change of momentum. When mass is constant, that simplifies to F equals m a." },
              { "id": "s3", "text_en": "Momentum is what a moving body has. Force is what changes that momentum. They are different physical quantities and don't equal each other." }
            ]
          }
        }
      }
    }
