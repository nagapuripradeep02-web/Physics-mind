        "teacher_script": {
          "tts_sentences": [
            { "id": "s1", "text_en": "You push a two kilogram trolley on a smooth floor — almost no friction." },
            { "id": "s2", "text_en": "Steady push, ten newtons, in one direction. What does the trolley do?" },
            { "id": "s3", "text_en": "Many students reflexively say it slides at a fixed speed because the push is fixed." },
            { "id": "s4", "text_en": "But a constant force does not mean constant speed. The trolley starts at zero, and its speed grows. It accelerates." },
            { "id": "s5", "text_en": "Newton's second law tells us by how much. The push sets the acceleration — speed evolves from there." }
          ]
        }
      },
