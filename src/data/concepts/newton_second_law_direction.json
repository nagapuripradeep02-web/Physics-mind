  },
  "physics_engine_config": {
    "variables": {
      "F": {
        "name": "Applied force magnitude",
        "unit": "N",
        "min": 1,
        "max": 50,
        "default": 10,
        "step": 1
      },
      "m": {
        "name": "Block mass",
        "unit": "kg",
        "min": 0.5,
        "max": 10,
        "default": 2,
        "step": 0.5
      },
      "theta_F": {
        "name": "Force angle from horizontal",
        "unit": "deg",
        "min": 0,
        "max": 90,
        "default": 0,
        "step": 5
      },
      "t": {
        "name": "Time since force applied",
        "unit": "s",
        "min": 0,
        "max": 5,
        "default": 1,
        "step": 0.1
      }
    },
    "computed_outputs": {
      "a_mag": {
        "formula": "F / m"
      },
      "a_x": {
        "formula": "(F * cos(theta_F * PI / 180)) / m"
      },
      "a_y": {
        "formula": "(F * sin(theta_F * PI / 180)) / m"
      },
      "v_x_at_t": {
        "formula": "a_x * t"
      },
      "v_y_at_t": {
        "formula": "a_y * t"
      },
      "v_mag_at_t": {
        "formula": "sqrt(v_x_at_t * v_x_at_t + v_y_at_t * v_y_at_t)"
      }
    },
    "formulas": {
      "newton_second_law": "F_net = m · a (vector equation — direction matters)",
      "magnitude_only": "|a| = |F_net| / m",
      "component_form": "a_x = F_x / m, a_y = F_y / m (each component independently)",
      "velocity_from_acceleration": "v(t) = v_0 + a · t (starting at rest: v(t) = a · t)"
    },
    "constraints": [
      "F = m·a holds for the NET force on the body — sum of all forces, not just the applied one",
      "a points along F_net at every instant; v does NOT in general — v is the time-integral of a",
      "Mass is a scalar — it scales magnitude only, never changes direction",
      "If F_net = 0, then a = 0 (Newton I as a special case); v can still be non-zero (constant motion)",
      "Each component of F maps to the same-named component of a independently (a_x = F_x/m, a_y = F_y/m)"
    ]
  },
