            "label": "a",
            "color": "#10B981",
            "scale_pixels_per_unit": 4
          },
          {
            "type": "annotation",
            "text": "Inextensible means length cannot change.\nBoth ends move at the same speed.\nSo both blocks share the same acceleration a.",
            "position": {
              "x": 120,
              "y": 420
            },
            "style": "callout"
          },
          {
            "type": "label",
            "text": "Rule 1",
            "position": {
              "x": 100,
              "y": 120
            },
            "font_size": 24,
            "color": "#3B82F6",
            "bold": true
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Rule one. The string is inextensible, meaning its length cannot stretch."
            },
            {
              "id": "s2",
              "text_en": "If the string cannot stretch, both of its ends must always move at the same speed."
            },
            {
              "id": "s3",
              "text_en": "Equal speed means equal acceleration. So M and m accelerate together with the same value of a."
            },
            {
              "id": "s4",
              "text_en": "This is how we build the constraint equation that links two otherwise separate blocks."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
