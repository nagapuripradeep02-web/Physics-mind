            "style": "callout"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Imagine cutting the string."
            },
            {
              "id": "s2",
              "text_en": "The mango immediately starts to fall because the upward force has vanished."
            },
            {
              "id": "s3",
              "text_en": "That missing upward force was the tension. It lived inside the string."
            },
            {
              "id": "s4",
              "text_en": "At equilibrium, tension equals weight. T equals mg equals nine point eight newtons, pointing straight up along the string."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
