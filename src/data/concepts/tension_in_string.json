          {
            "type": "force_arrow",
            "from": "mass_2_center",
            "magnitude_expr": "m2*9.8",
            "direction_deg": 270,
            "label_expr": "m₂g = {(m2*9.8).toFixed(1)} N",
            "color": "#EF4444",
            "scale_pixels_per_unit": 3
          },
          {
            "type": "formula_box",
            "equation_expr": "T = 2m₁m₂g / (m₁+m₂) = {((2*m1*m2*9.8)/(m1+m2)).toFixed(1)} N    a = (m₁-m₂)g / (m₁+m₂) = {(((m1-m2)*9.8)/(m1+m2)).toFixed(2)} m/s²",
            "position": {
              "x": 60,
              "y": 430
            }
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "The Atwood machine has two masses hanging from one string over a massless pulley."
            },
            {
              "id": "s2",
              "text_en": "The heavier mass m one falls while the lighter m two rises. Both share the same tension T and the same acceleration a."
            },
            {
              "id": "s3",
              "text_en": "Apply Newton's second law to each block. Eliminate T between the two equations."
            },
            {
              "id": "s4",
              "text_en": "The result is a beautiful formula: T equals two m one m two g divided by m one plus m two — the harmonic mean of the two weights."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
