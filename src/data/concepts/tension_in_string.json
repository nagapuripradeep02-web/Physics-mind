              ]
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "This is the core difference between a string and a rigid rod."
              },
              {
                "id": "s2",
                "text_en": "A string can only pull. Try to push it and it simply buckles — it cannot carry a compression."
              },
              {
                "id": "s3",
                "text_en": "A rod is rigid. It can push and pull along its length."
              },
              {
                "id": "s4",
                "text_en": "In exam problems, whenever you see the word string, tension can only be zero or positive — never negative."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        },
        "EPIC_C_2": {
          "title": "When a String Goes Slack — T = 0, Not Negative",
          "scene_composition": [
            {
              "type": "vector",
              "from": {
