              "style": "callout"
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "This is a common confusion. Does the tension vary along the string, or not?"
              },
              {
                "id": "s2",
                "text_en": "Answer: in a massless string, T is exactly the same at every point."
              },
              {
                "id": "s3",
                "text_en": "A massless string has no internal mass to accelerate, so no extra pulling is needed to carry any segment along."
              },
              {
                "id": "s4",
                "text_en": "If the string had real mass and the system were accelerating, tension would be larger at the top and smaller at the bottom."
              }
            ]
          },
