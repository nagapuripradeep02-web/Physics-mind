{
  "concept_id": "tension_in_string",
  "concept_name": "Tension in String",
  "chapter": 8,
  "section": "8.1",
  "renderer_pair": {
    "panel_a": "mechanics_2d",
    "panel_b": "graph_interactive"
  },
  "real_world_anchor": {
    "primary": "A mango dangles from a thread tied to the ceiling. The thread pulls upward on the mango. Cut the thread and it falls — the upward pull is gone.",
    "secondary": "A bucket of water rises from a well. The rope pulls the bucket up; by Newton's third law, the bucket pulls the rope down. That mutual pull is the tension.",
    "tertiary": "An Atwood machine has unequal masses on two ends of a single rope. The system accelerates, but the tension has the same value on both sides — why?"
  },
  "physics_engine_config": {
    "formulas": {
      "single_hanging_mass_equilibrium": "T = mg",
      "single_hanging_mass_acceleration": "T = m(g - a) for upward acceleration",
      "atwood_tension": "T = (2 * m1 * m2 * g) / (m1 + m2)",
      "atwood_acceleration": "a = (m1 - m2) * g / (m1 + m2)"
    },
    "variables": {
      "m1": {
        "name": "Mass 1",
        "unit": "kg",
        "min": 0.5,
        "max": 5,
        "default": 2
      },
      "m2": {
        "name": "Mass 2",
        "unit": "kg",
        "min": 0.5,
        "max": 5,
        "default": 1
      },
      "g": {
        "name": "gravitational acceleration",
        "unit": "m/s²",
        "constant": 9.8
      },
      "T": {
        "name": "Tension",
        "unit": "N",
        "derived": "(2 * m1 * m2 * g) / (m1 + m2)"
      },
      "a": {
        "name": "acceleration",
        "unit": "m/s²",
        "derived": "(m1 - m2) * g / (m1 + m2)"
      }
    },
    "string_rules": [
      {
        "rule_number": 1,
        "name": "Inextensible string",
        "statement": "If the string is inextensible, the acceleration magnitude is the same for all masses connected by it.",
        "implication": "|a₁| = |a₂| = ... = a"
      },
      {
        "rule_number": 2,
        "name": "Massless string",
        "statement": "If the string is massless, the tension is the same at every point along it.",
        "implication": "T at any point = T_total"
      },
      {
        "rule_number": 3,
        "name": "Massless, frictionless pulley",
        "statement": "If the pulley is massless and frictionless, the tension is the same on both sides of the pulley.",
        "implication": "T_left = T_right"
      }
    ],
    "constraints": [
      "A string can only PULL — it cannot push.",
      "String tension acts AWAY from the body, along the direction of the string.",
      "If the string breaks, T = 0 instantly.",
      "A rod can both push and pull; a string can only pull."
    ]
  },
  "epic_l_path": {
    "state_count": 6,
    "states": {
