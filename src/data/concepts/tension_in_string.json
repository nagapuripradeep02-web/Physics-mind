          {
            "type": "force_arrow",
            "from": "mass_2_top_center",
            "magnitude_expr": "(2*m1*m2*9.8)/(m1+m2)",
            "direction_deg": 90,
            "label_expr": "T = {((2*m1*m2*9.8)/(m1+m2)).toFixed(1)} N",
            "color": "#10B981",
            "scale_pixels_per_unit": 3
          },
          {
            "type": "force_arrow",
            "from": "mass_1_center",
            "magnitude_expr": "m1*9.8",
