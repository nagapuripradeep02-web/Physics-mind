            "scale_pixels_per_unit": 6
          },
          {
            "type": "annotation",
            "text": "Something must be pulling it up —\notherwise it would fall.\nWhere does that pull come from?",
            "position": {
              "x": 560,
              "y": 220
            },
            "style": "callout"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "A mango hangs from a thread attached to the ceiling. Gravity pulls it downward with a force of nine point eight newtons."
            },
            {
              "id": "s2",
              "text_en": "Yet it does not fall. Something upward must be balancing gravity."
            },
            {
              "id": "s3",
              "text_en": "That upward force comes from the thread. But how exactly does a thread apply a force?"
            },
            {
              "id": "s4",
              "text_en": "We call that force tension. Today we will see what tension really is and where it comes from."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
