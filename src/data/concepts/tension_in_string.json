      "states": {
        "EPIC_C_1": {
          "title": "Your Belief: String Can Push",
          "scene_composition": [
            {
              "type": "comparison_panel",
              "left_label": "String — pull only",
              "right_label": "Rod — push AND pull",
              "left_scene": [
                {
                  "type": "annotation",
                  "text": "Taut string: T > 0 (pull only).\nSlack string: T = 0.\nCompressing a string is impossible — it just bends.",
                  "position": {
                    "x": 20,
                    "y": 100
                  }
                }
              ],
              "right_scene": [
                {
                  "type": "annotation",
                  "text": "Rod pushed: compression works.\nRod pulled: tension works.\nA rigid rod supports both directions.",
