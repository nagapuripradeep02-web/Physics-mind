              "style": "callout",
              "color": "#EF4444"
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "The tension in a string is always non-negative. Either T is positive or T equals zero."
              },
              {
                "id": "s2",
                "text_en": "A zero tension simply means the string has gone slack. No force is transmitted."
              },
              {
                "id": "s3",
                "text_en": "If your calculation ever produces a negative T, your assumption about the direction of motion or about the string segment is wrong."
              },
              {
                "id": "s4",
                "text_en": "Revisit the diagram. Flip the assumed direction of acceleration or of the string segment, and redo the algebra."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        }
      }
