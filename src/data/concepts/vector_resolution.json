          {
            "type": "annotation",
            "id": "along_slope",
            "text": "ALONG the slope:\nmg sinθ = 9.80 N\n→ pulls the block down the ramp.\nTHIS is the sliding force.",
            "position": {
              "x": 480,
              "y": 230
            },
            "style": "callout",
            "color": "#10B981"
          },
          {
            "type": "annotation",
            "id": "perpendicular",
            "text": "PERPENDICULAR:\nmg cosθ = 16.97 N\n→ pushes block into surface.\nSurface pushes back → that IS N.",
            "position": {
