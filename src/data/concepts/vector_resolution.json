  "epic_c_branches": [
    {
      "branch_id": "swapped_sin_cos",
      "misconception": "Student swaps sine and cosine — thinks Fx = F sinα.",
      "trigger_phrases": [
        "isn't Fx equal to F sin",
        "why not F sin alpha for horizontal",
        "sin for horizontal",
        "i thought sine was the x component",
        "cos gives the vertical"
      ],
      "state_sequence": [
        "EPIC_C_1",
        "EPIC_C_2"
      ],
      "states": {
        "EPIC_C_1": {
          "title": "Check: which side of the triangle is which?",
          "scene_composition": [],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Pause — this is a very common confusion. Let us settle it forever."
              },
              {
                "id": "s2",
                "text_en": "In a right triangle, cosine equals ADJACENT over hypotenuse. Sine equals OPPOSITE over hypotenuse."
              },
              {
                "id": "s3",
                "text_en": "The angle alpha is measured from the x-axis. So the x-axis is the side NEXT to the angle. That is the adjacent side."
              },
              {
                "id": "s4",
                "text_en": "Adjacent pairs with cosine. That means x pairs with cosine. Always."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        },
        "EPIC_C_2": {
          "title": "The Safe Rule — cos with the axis you measured FROM",
          "scene_composition": [],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "If you ever forget, use this one rule: cosine goes with the axis you measured the angle FROM."
              },
              {
                "id": "s2",
                "text_en": "Measured from x? Then Fx is F cos alpha, Fy is F sin alpha."
              },
              {
                "id": "s3",
                "text_en": "Measured from y? Then Fy is F cos alpha, Fx is F sin alpha."
              },
              {
                "id": "s4",
                "text_en": "It is always cosine with the axis you measured from. Never the other way around."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        }
      }
    }
  ],
