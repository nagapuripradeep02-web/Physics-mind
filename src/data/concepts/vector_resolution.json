          {
            "type": "annotation",
            "id": "question_hook",
            "text": "You pull with 10 N at 50°.\nThe trolley only moves along the ground.\nHow much of your pull actually moves it forward?",
            "position": {
              "x": 475,
              "y": 150
            },
            "style": "callout",
            "color": "#3B82F6"
          },
          {
            "type": "label",
            "id": "origin_label",
            "text": "O",
            "position": {
              "x": 235,
              "y": 390
            },
            "color": "#F59E0B",
            "font_size": 14
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Here is a question that trips up almost every physics student."
            },
            {
              "id": "s2",
              "text_en": "You pull a trolley with a rope at an angle — say fifty degrees above the ground."
            },
            {
              "id": "s3",
              "text_en": "You are applying ten Newtons of force. But the trolley only moves forward, along the ground."
            },
            {
              "id": "s4",
              "text_en": "So how much of your ten Newton pull actually moves it? Ten? Half? Something else?"
            },
            {
              "id": "s5",
              "text_en": "The answer lies in a powerful idea called resolving a vector. Let us see it."
            }
          ]
        }
      },
      "STATE_2": {
        "title": "The Shadow Trick — Perpendicular Projection",
        "duration": 12,
        "advance_mode": "auto_after_tts",
        "focal_primitive_id": "F_components",
        "scene_composition": [
          {
            "type": "surface",
            "id": "ground",
            "orientation": "horizontal",
            "position": {
              "x": 120,
              "y": 380
            },
            "length": 420,
            "texture": "rough"
          },
          {
            "type": "body",
            "id": "origin_point",
            "shape": "circle",
            "size": 10,
            "position": {
              "x": 250,
              "y": 372
            },
            "fill_color": "#1F2937",
            "border_color": "#F59E0B",
            "border_width": 2
          },
          {
            "type": "force_arrow",
            "id": "F_arrow",
            "force_id": "main_vector",
            "origin_body_id": "origin_point",
            "origin_anchor": "body_center",
            "color": "#3B82F6",
