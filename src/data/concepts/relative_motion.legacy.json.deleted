      { "id": "v_rel", "label": "v_rel" },
      { "id": "zero_ref", "label": "Zero reference" }
    ],
    "states": {
      "STATE_1": { "active_lines": ["v_a", "v_b"], "show_sliders": false, "highlight_point": false },
      "STATE_2": { "active_lines": ["v_a", "v_b"], "show_sliders": false, "highlight_point": false },
      "STATE_3": { "active_lines": ["v_a", "v_b", "zero_ref"], "show_sliders": false, "highlight_point": false },
      "STATE_4": { "active_lines": ["v_a", "v_b", "v_rel", "zero_ref"], "show_sliders": false, "highlight_point": true, "point_x": 5, "point_y": 10, "label": "v_AB = v_A - v_B = 10" },
      "STATE_5": { "active_lines": ["v_rel", "zero_ref"], "show_sliders": false, "highlight_point": false },
