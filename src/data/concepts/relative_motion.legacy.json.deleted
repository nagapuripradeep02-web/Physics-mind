    },
    "x_axis": { "label": "Time", "symbol": "t", "unit": "s", "min": 0, "max": 10 },
    "y_axis": { "label": "Velocity", "symbol": "v", "unit": "m/s", "min": -20, "max": 40 },
    "lines": [
      { "id": "v_a", "slope": 0, "intercept": 30, "color": "#60a5fa", "label": "v_A = 30 m/s" },
      { "id": "v_b", "slope": 0, "intercept": 20, "color": "#34d399", "label": "v_B = 20 m/s" },
      { "id": "v_rel", "slope": 0, "intercept": 10, "color": "#fbbf24", "label": "v_A relative to B = 10 m/s" },
      { "id": "zero_ref", "slope": 0, "intercept": 0, "color": "#ef4444", "dash": "dash", "label": "Zero reference" }
    ],
    "sliders": [],
    "legend": [
      { "id": "v_a", "label": "v_A" },
