        "type": "numerical",
        "answer": "120°",
        "wrong_answer_routes_to": "resultant_formula",
        "difficulty": "medium"
      },
      {
        "q_id": "Q3",
        "text": "Can resultant of 7N and 3N ever be 3N?",
        "type": "conceptual",
        "answer": "No. R_min=|7−3|=4N",
        "wrong_answer_routes_to": "resultant_always_larger",
        "difficulty": "medium"
      },
      {
        "q_id": "Q4",
        "text": "Forces A and B have resultant R. If A reversed, new resultant is also R. Find angle between A and B.",
        "type": "algebraic",
        "answer": "90°",
        "wrong_answer_routes_to": "resultant_formula",
        "difficulty": "hard"
      }
    ]
