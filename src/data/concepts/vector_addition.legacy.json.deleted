    "sync_behaviour": "Panel B live dot tracks current θ as Panel A animates vectors. Active in STATE_6 only."
  },
  "jee_specific": {
    "common_traps": [
      {
        "trap": "Using R=A+B without checking θ=0°",
        "frequency": "very_common",
        "catch_phrase": "Whenever θ given, use full formula"
      },
      {
        "trap": "Assuming R_min=0 for any two vectors",
        "frequency": "common",
        "catch_phrase": "R=0 only when A=B and θ=180°; otherwise R_min=|A−B|"
      },
      {
        "trap": "Applying Pythagoras at non-90° angles",
        "frequency": "common",
        "catch_phrase": "R=√(A²+B²) ONLY at θ=90°"
      },
      {
        "trap": "Confusing α (direction of R) with θ (angle between A and B)",
        "frequency": "common",
        "catch_phrase": "α and θ are different angles in different formulas"
      },
      {
        "trap": "Treating R=A+B and R=|A−B| as typical values not boundaries",
        "frequency": "moderate",
        "catch_phrase": "These are boundaries only — typical R lies strictly between them"
      }
    ],
    "high_yield_formulas": [
      "R = √(A² + B² + 2AB cosθ)",
      "tan α = (B sinθ) / (A + B cosθ)",
      "R_max = A+B at θ=0°",
      "R_min = |A−B| at θ=180°",
      "R (equal vectors) = 2A cos(θ/2)"
    ],
    "neet_relevance": "Force equilibrium problems. Range inequality and perpendicular Pythagoras case are most tested.",
    "standard_values_to_memorise": [
      "θ=0°: R=A+B",
      "θ=60°: R=√(A²+B²+AB)",
      "θ=90°: R=√(A²+B²)",
      "θ=120°: R=√(A²+B²−AB)",
      "θ=180°: R=|A−B|"
    ]
  },
  "concept_relationships": {
    "prerequisites": [
      "scalars_vs_vectors",
      "basic_trigonometry"
    ],
    "leads_to": [
      "resolution_of_vectors",
      "vector_subtraction",
      "relative_motion",
      "projectile_motion"
    ],
    "commonly_confused_with": [
      "scalar_addition",
      "vector_subtraction"
    ],
    "cross_concept_link": "R=√(A²+B²) at θ=90° IS the Pythagorean theorem — vector addition and right-triangle geometry are the same relationship.",
    "exam_combos": [
      "vector_addition + relative_motion (river-boat)",
      "vector_addition + Newton's laws (force equilibrium)"
    ]
  },
