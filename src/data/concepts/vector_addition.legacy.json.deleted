      ]
    },
    "misconception_branch_map": {
      "always larger|bigger than both|hamesha bada|resultant zyada hoga": "resultant_always_larger",
      "just add|scalar|3+4=7|seedha add|only magnitude|sirf number": "scalar_addition",
