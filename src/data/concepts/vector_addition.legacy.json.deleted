  "regeneration_variants": [
    {
      "variant_id": "geometry_first",
      "approach_pill_label": "Geometry view",
      "variant_index": 1,
      "summary": "Start with the shape before the formula",
      "entry_state": "STATE_2",
      "state_sequence": [
        "STATE_2",
        "STATE_3",
        "STATE_5",
        "STATE_6"
      ],
      "teaching_emphasis": "Parallelogram diagonal IS the resultant. Formula is just naming it.",
      "variant_scripts": {
        "STATE_2": {
          "step_label": "Build the parallelogram",
          "teacher_script": "Let's skip the formula entirely — start with the shape. Place both vectors tail-to-tail from the same origin. Watch the parallelogram construct itself. That bold diagonal from O to the opposite corner — that IS your resultant R. No formula needed to see it. The length of that diagonal is your answer.",
          "attention_cue": "The diagonal appearing — that's R"
        },
        "STATE_3": {
          "step_label": "Triangle law confirms it",
          "teacher_script": "Now watch the triangle law give the same R. B slides so its tail meets A's head. The resultant arrow closes the triangle — identical length, identical direction. Triangle law and parallelogram law are not different physics. Two views, one truth. Same R every time.",
          "attention_cue": "Same arrow length — different shape, same answer"
        },
        "STATE_5": {
          "step_label": "Geometry explains the arithmetic",
          "teacher_script": "Your eye already told you why 4+3 equals 5, not 7. The diagonal is always shorter than the sum of two sides of a parallelogram. The angle between vectors costs you resultant magnitude. The geometry explains the arithmetic — no calculation needed to understand why.",
          "attention_cue": "The gap between path length 7 and diagonal length 5"
        },
        "STATE_6": {
          "step_label": "Feel it yourself",
          "teacher_script": "Drag the angle between the vectors. Watch the diagonal change. At θ=0° the parallelogram collapses to a line and R hits maximum — 7. At θ=180° they pull against each other and R drops to 1. The shape tells the story. Try it.",
          "attention_cue": "Diagonal growing and shrinking as you drag"
        }
      }
    },
    {
      "variant_id": "formula_first",
      "approach_pill_label": "Formula view",
      "variant_index": 2,
      "summary": "Start with the equation, then prove it geometrically",
      "entry_state": "STATE_4",
      "state_sequence": [
        "STATE_4",
        "STATE_5",
        "STATE_6"
      ],
      "teaching_emphasis": "The cosθ interaction term controls everything. Geometry is visual proof of the algebra.",
      "variant_scripts": {
        "STATE_4": {
          "step_label": "The formula — three terms",
          "teacher_script": "Start here: R equals the square root of A-squared plus B-squared plus 2-A-B-cos-theta. Three terms. A-squared is A's self-contribution. B-squared is B's. And 2ABcosθ is the interaction term — entirely controlled by angle. At θ=0° it adds 2AB. At θ=90° it vanishes. At θ=180° it subtracts 2AB. Three cases — watch all three now.",
          "attention_cue": "The interaction term 2ABcosθ — this is what angle controls"
        },
        "STATE_5": {
          "step_label": "Formula meets geometry",
          "teacher_script": "Now the geometry makes the algebra real. R equals 5, not 7. Plug in θ=90°: cosθ=0, the interaction term vanishes, R equals root of 16 plus 9 equals 5. The formula predicts exactly what the diagonal shows. The formula is naming the geometry — they're the same truth in two languages.",
          "attention_cue": "R = 5 confirmed two ways — formula and diagonal agree"
        },
        "STATE_6": {
          "step_label": "Drive the formula yourself",
          "teacher_script": "Drag the angle. Every position is the formula computing in real time. Find where R is maximum — that's θ=0°, the +2AB case. Find where R equals exactly root of A-squared plus B-squared — that's θ=90°. Find where R is minimum — θ=180°, the -2AB case. The slider is your formula evaluator.",
          "attention_cue": "R changing in real time — feel the formula"
        }
      }
    },
    {
      "variant_id": "explore_yourself",
      "approach_pill_label": "Explore yourself",
      "variant_index": 3,
      "summary": "Discover the relationship through the slider before any explanation",
      "entry_state": "STATE_6",
      "state_sequence": [
        "STATE_6",
        "STATE_4",
        "STATE_2",
        "STATE_5"
      ],
      "teaching_emphasis": "Student discovers the angle-dependence pattern before being told. Formula and geometry confirm what they felt.",
      "variant_scripts": {
        "STATE_6": {
          "step_label": "Discover — no explanation yet",
          "teacher_script": "Here are two vectors A and B. The angle between them is yours to control. Drag the slider. No formulas yet — just watch what happens to the resultant arrow as you move it. What pattern do you notice? When does R get largest? When does it get smallest? Take thirty seconds and find out.",
          "attention_cue": "Watch the resultant arrow — what changes as you drag?"
        },
        "STATE_4": {
          "step_label": "Name what you felt",
          "teacher_script": "You felt it before I named it. Maximum R when vectors point the same way. Minimum R when they oppose each other. The formula captures exactly this: R equals root of A-squared plus B-squared plus 2ABcosθ. The 2ABcosθ interaction term is what you just felt on the slider. Large and positive when θ is small. Zero at 90°. Large and negative at 180°.",
          "attention_cue": "The interaction term — this is the pattern you discovered"
        },
        "STATE_2": {
          "step_label": "Now see why geometrically",
          "teacher_script": "Now see the geometry that explains it. Both vectors from origin form a parallelogram. The diagonal is R. When θ=0° the parallelogram collapses to a line — R is maximum at 7. When θ=90° you get a rectangle — R is 5. When θ=180° both vectors pull opposite — R nearly cancels. Your slider was controlling the shape of this parallelogram.",
          "attention_cue": "Parallelogram shape changes — your slider was controlling this"
        },
        "STATE_5": {
          "step_label": "The aha is yours",
          "teacher_script": "The key insight is already yours — you discovered it first. R is never simply A plus B unless the vectors are perfectly aligned at θ=0°. Every JEE problem with two forces, two velocities, any two vectors — the angle between them controls the outcome. You now know this in your bones, not just your notes.",
          "attention_cue": "R = 5, not 7 — you already knew this from the slider"
        }
      }
    }
  ],
