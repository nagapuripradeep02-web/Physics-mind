      ]
    },
    "hc_verma": {
      "volume": 1,
      "chapter": 2,
      "sections": [
        "2.5",
        "2.6"
      ]
    }
  },
  "source_type": "ncert_and_dc_pandey",
  "three_js_flag": false,
  "three_js_note": "2D concept. Parallelogram and triangle construction fully handled by mechanics_2d (p5.js/canvas2d). No 3D rendering needed.",
  "renderer_hint": {
    "technology": "canvas2d",
    "technology_b": "plotly",
    "renderer": "mechanics_2d",
    "panel_count": 2,
    "sync_required": true,
    "scenario_type": "vector_addition",
    "scene_mode": false,
    "show_labels": true,
    "panel_a_role": "Animated parallelogram — vectors A and B from common origin, resultant R updating live as angle θ changes",
    "panel_b_role": "Plotly: R vs θ curve (0–180°) — live dot tracks current angle in STATE_6 only"
  },
  "locked_facts": {
    "resultant_formula": "R = √(A² + B² + 2AB cosθ)",
    "direction_formula": "tan α = (B sinθ) / (A + B cosθ)",
    "range_inequality": "|A − B| ≤ R ≤ A + B",
    "r_max": "R_max = A + B at θ = 0°",
    "r_min": "R_min = |A − B| at θ = 180°",
    "pythagoras_case": "R = √(A² + B²) at θ = 90° ONLY",
    "equal_vectors": "R = 2A cos(θ/2) when both magnitudes are A",
    "commutativity": "A + B = B + A — vector addition is commutative",
    "costheta_role": "The 2AB cosθ term is zero at 90°, positive below, negative above"
  },
  "minimum_viable_understanding": "The resultant of two vectors depends on BOTH their magnitudes AND the angle between them — changing the angle changes R completely, and R obeys |A−B| ≤ R ≤ A+B.",
  "variables": {
    "A": {
      "description": "Magnitude of first vector",
      "symbol": "A",
      "unit": "N or m",
      "default_value": 4
    },
    "B": {
      "description": "Magnitude of second vector",
      "symbol": "B",
      "unit": "N or m",
      "default_value": 3
    },
    "theta": {
      "description": "Angle between vectors A and B",
      "symbol": "θ",
      "unit": "degrees",
      "range": [
        0,
        180
      ],
      "default_value": 60
    },
    "R": {
      "description": "Magnitude of resultant vector",
      "symbol": "R",
      "unit": "same as A and B",
      "computed": true
    },
    "alpha": {
      "description": "Angle of resultant R measured from vector A",
      "symbol": "α",
      "unit": "degrees",
      "computed": true
    }
  },
  "available_renderer_scenarios": {
    "epic_l": [
      "two_vectors_given",
      "parallelogram_law",
      "triangle_law",
      "resultant_formula",
