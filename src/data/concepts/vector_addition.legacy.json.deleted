            "scenario": "graph_single_dot",
            "point_x": 60,
            "point_y": 7.0
          },
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "R = root of A squared plus B squared plus 2AB cosine theta. At sixty degrees with A=4, B=3: R approximately six point zero eight.",
                "sync_point": "formula_overlaid",
                "pause_after_ms": 400,
                "tts_style": "calm_explain",
                "no_translate_tokens": [
                  "cosine theta"
                ]
              }
            ]
          }
        },
        {
          "physics_layer": {
            "scenario": "special_cases_0_90_180"
          },
          "panel_b_layer": {
            "scenario": "graph_reference_points"
          },
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "At ninety degrees cosine theta is zero — that gives Pythagoras. At zero degrees cosine is one — that gives scalar sum.",
                "sync_point": "special_cases_shown",
                "pause_after_ms": 400,
                "tts_style": "calm_explain",
                "no_translate_tokens": [
                  "cosine theta",
