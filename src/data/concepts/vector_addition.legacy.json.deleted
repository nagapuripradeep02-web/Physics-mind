  "static_responses": {
    "define_vector_addition": "Vector addition produces resultant R from vectors A and B. R = √(A²+B²+2AB cosθ) where θ is angle between them. Both parallelogram law and triangle law give identical results.",
    "state_range_inequality": "|A−B| ≤ R ≤ A+B. Resultant lies between difference and sum of individual magnitudes. Exact value depends on θ.",
    "special_case_perpendicular": "When θ=90°, R = √(A²+B²). This is Pythagoras — valid ONLY at exactly 90°.",
    "commutativity_statement": "Vector addition is commutative: A+B = B+A. Same resultant regardless of order.",
    "equal_vectors_shortcut": "Two equal vectors each magnitude A at angle θ: R = 2A cos(θ/2)."
  },
  "problem_guidance_path": {
    "general_approach": [
      "Step 1: Identify vectors and angle θ between them",
      "Step 2: Check θ = 0°, 90°, or 180° — use shortcut if so",
      "Step 3: Otherwise apply R = √(A²+B²+2AB cosθ)",
      "Step 4: If direction asked, use tan α = (B sinθ)/(A+B cosθ)",
      "Step 5: Verify R lies within |A−B| ≤ R ≤ A+B"
    ],
    "shortcut_check": "θ=90°→Pythagoras. θ=0°→R=A+B. θ=180°→R=|A−B|. Otherwise full formula."
  },
  "example_library": {
    "example_1": {
      "source": "DC Pandey Mechanics Vol 1, Ch.5",
      "type": "numerical",
      "description": "Two forces 3N and 4N at 90°",
      "approach": "R=√(9+16)=5N; tan α=3/4→α=37° from 4N force",
      "use_for": "perpendicular case, 3-4-5 triangle shortcut"
    },
    "example_2": {
      "source": "DC Pandey Mechanics Vol 1, Ch.5",
      "type": "numerical",
      "description": "Two equal forces A=5N at θ=60°",
      "approach": "R=2A cos(θ/2)=2×5×cos30°=5√3 N",
      "use_for": "equal vector symmetric formula"
    },
    "example_3": {
      "source": "JEE Previous Year",
      "type": "algebraic",
      "description": "Resultant of P and Q is R. When Q doubled, R doubles. Find angle.",
      "approach": "Set up two equations, eliminate → θ=90°",
      "use_for": "algebraic elimination, JEE-style manipulation"
    },
    "example_4": {
      "source": "DC Pandey Mechanics Vol 1, Ch.5",
      "type": "conceptual",
      "description": "Can resultant of 3 and 4 be (a)8? (b)1? (c)5?",
      "approach": "Range [1,7]: (a) NO. (b) YES at θ=180°. (c) YES at θ=90°",
      "use_for": "range inequality comprehension"
    }
  },
  "assessment_path": {
    "trigger": "opt_in_only",
    "trigger_phrase": "Test me",
    "questions": [
      {
        "q_id": "Q1",
        "text": "Two forces 5N and 12N at right angles. Find resultant.",
