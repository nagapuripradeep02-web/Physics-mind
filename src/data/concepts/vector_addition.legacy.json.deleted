        },
        "STATE_2": {
          "label": "Law in NCERT words",
          "phase": 1,
          "physics_layer": {
            "scenario": "parallelogram_law",
            "freeze_at_t": 0
          },
          "panel_b_layer": {
            "scenario": "graph_empty_axes"
          },
          "advance_mode": "auto_after_tts",
          "exam_overlay": {
            "marks_breakdown": [
              "Law statement: 1 mark — NCERT verbatim required"
            ],
            "common_mistakes": "Paraphrasing the law loses the mark. Write NCERT exact wording."
          },
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "NCERT exact wording: If two vectors acting at a point are represented in magnitude and direction by the two adjacent sides of a parallelogram, their resultant is represented by the diagonal of the parallelogram passing through that point.",
                "sync_point": "state_complete",
                "pause_after_ms": 800,
                "tts_style": "exam_serious",
                "no_translate_tokens": [
                  "parallelogram",
                  "resultant",
                  "diagonal"
                ]
              }
            ],
            "exam_tip_en": "Write this word for word. Examiner checks for 'adjacent sides' and 'diagonal passing through that point'."
          }
        },
        "STATE_3": {
          "label": "Magnitude derivation",
          "phase": 2,
          "physics_layer": {
            "scenario": "resultant_formula",
            "freeze_at_t": 0
          },
          "panel_b_layer": {
            "scenario": "graph_empty_axes"
          },
          "advance_mode": "auto_after_tts",
          "exam_overlay": {
            "marks_breakdown": [
              "Apply cosine rule: 1 mark",
              "Arrive at R = √(A²+B²+2ABcosθ): 1 mark"
            ],
            "common_mistakes": "Show every algebraic step. Explicitly show angle OAC = 180°−θ."
          },
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Apply cosine rule to triangle. OC squared equals OA squared plus AC squared minus 2 times OA times AC times cosine of angle OAC.",
                "sync_point": "formula_overlaid",
                "pause_after_ms": 800,
                "tts_style": "exam_serious",
                "no_translate_tokens": [
                  "cosine"
                ]
              },
              {
                "id": "s2",
                "text_en": "Angle OAC equals one-eighty minus theta. Cosine of one-eighty minus theta equals minus cosine theta. Simplify to get R squared equals A squared plus B squared plus 2AB cosine theta.",
                "sync_point": "step_2_complete",
                "pause_after_ms": 1000,
                "tts_style": "exam_serious",
                "no_translate_tokens": [
                  "cosine theta"
                ]
              }
            ],
            "exam_tip_en": "Show angle OAC = 180°−θ explicitly. Examiners check this step."
          }
        },
        "STATE_4": {
          "label": "Draw the diagram",
          "phase": 2,
          "renderer": "diagram_tutor_renderer",
          "advance_mode": "interaction_complete",
          "exam_overlay": {
            "marks_breakdown": [
              "Correct labelled diagram: 1 mark — all 7 elements required"
            ],
            "common_mistakes": "Arrow on R is mandatory. Missing θ label loses the diagram mark."
          },
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Draw the diagram step by step. Seven elements — all required for the mark.",
                "sync_point": "animation_start",
                "pause_after_ms": 400,
                "tts_style": "exam_serious",
                "no_translate_tokens": []
              }
            ],
            "exam_tip_en": "Seven elements: O, A, B, R all labelled, θ labelled, arrow on R, dashed completion lines."
          }
        },
        "STATE_5": {
          "label": "Direction formula",
          "phase": 2,
          "physics_layer": {
            "scenario": "resultant_formula",
            "freeze_at_t": 0
          },
          "panel_b_layer": {
            "scenario": "graph_empty_axes"
          },
          "advance_mode": "auto_after_tts",
          "exam_overlay": {
            "marks_breakdown": [
              "Direction formula: 1 mark — tan α = (B sinθ)/(A+B cosθ)"
            ],
            "common_mistakes": "Students write only magnitude formula and forget direction. One mark lost every year."
          },
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Final step. Direction: tan alpha equals B sine theta divided by A plus B cosine theta. Write this. Every year students forget it.",
                "sync_point": "formula_overlaid",
                "pause_after_ms": 600,
                "tts_style": "exam_serious",
                "no_translate_tokens": [
                  "alpha",
                  "theta",
                  "cosine theta"
                ]
              }
            ],
            "exam_tip_en": "Write tan α = (B sinθ)/(A+B cosθ) immediately after magnitude formula. Do not skip it."
          }
        }
      }
    },
