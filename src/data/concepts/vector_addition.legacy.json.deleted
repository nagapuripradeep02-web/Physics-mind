    "triangle_law": "STATE_3"
  },
  "prerequisite_check": {
    "required_concepts": [
      "scalars_vs_vectors",
      "basic_trigonometry"
    ],
    "gate_question": "If a force has magnitude 5N pointing East — is that a scalar or a vector?",
    "if_gap_detected": "Route to scalars_vs_vectors first. Return here after completion.",
    "soft_check_trigger": "If student cannot distinguish magnitude from direction in first response, soft-route to scalar_vector_basics before STATE_2."
  },
  "epic_l_path": {
    "scope": "global",
    "state_count": 6,
    "states": {
      "STATE_1": {
        "state_id": "STATE_1",
        "label": "Hook — Two vectors",
        "physics_layer": {
          "scenario": "two_vectors_given",
          "params": {
            "vec_a": {
              "magnitude": 4,
              "angle_deg": 0,
              "label": "A",
              "color": "#4FC3F7"
            },
            "vec_b": {
              "magnitude": 3,
              "angle_deg": 90,
              "label": "B",
              "color": "#81C784"
            }
          },
          "freeze_at_t": 0,
          "show_parallelogram": false,
          "show_resultant": false
        },
        "panel_b_layer": {
          "scenario": "graph_empty_axes",
          "active_lines": [],
          "highlight_point": false
        },
        "advance_mode": "auto_after_tts",
        "locked_facts": [
          "Vector A = 4 units East, Vector B = 3 units North",
          "Direction is a mathematical input — not a label"
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "You walk 4 metres East, then 3 metres North. Where do you end up?",
              "sync_point": "vectors_appear",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": []
            },
            {
              "id": "s2",
              "text_en": "Most students say 7 metres — because 4 plus 3 is 7. But that is a scalar answer to a vector question.",
              "sync_point": "animation_start",
              "pause_after_ms": 800,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "scalar",
                "vector"
              ]
            },
            {
              "id": "s3",
              "text_en": "These two arrows are our vectors A and B. Both direction and magnitude matter here.",
              "sync_point": "state_complete",
              "pause_after_ms": 400,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "vector"
              ]
            }
          ]
        }
      },
      "STATE_2": {
        "label": "Parallelogram law — both from same origin",
        "physics_layer": {
          "scenario": "vector_addition",
          "animate_construction": true,
          "freeze": false,
          "construction_sequence": [
            "draw_vector_A",
            "draw_vector_B_from_origin",
            "draw_dashed_A_from_B_head",
            "draw_dashed_B_from_A_head",
            "flash_diagonal_resultant"
          ],
          "vector_A": {
            "magnitude": 4,
            "direction_deg": 30,
            "color": "#4FC3F7",
            "start": "origin"
          },
          "vector_B": {
            "magnitude": 3,
            "direction_deg": 90,
            "color": "#FF8A65",
            "start": "origin"
          },
          "resultant": {
            "color": "#66BB6A",
            "label": "R = diagonal",
            "from": "origin",
            "to": "parallelogram_opposite_corner"
          },
          "shade_parallelogram": true,
          "show_labels": true
        },
        "pedagogy_layer": {
          "cognitive_trigger": "Both vectors from the same origin — the parallelogram forms itself. That diagonal IS the resultant.",
          "real_world_anchor": "Two forces on an object — one East, one North. The object moves along the diagonal.",
          "attention_target": "The diagonal appearing from origin to opposite corner — that arrow IS R",
          "contrast_from_previous": "Triangle law showed tip-to-tail. Parallelogram law shows both from origin. Same R."
        },
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Draw both vectors from the same origin — point O.",
              "sync_point": "vectors_appear",
              "pause_after_ms": 400,
              "tts_style": "calm_explain",
              "no_translate_tokens": []
            },
            {
              "id": "s2",
              "text_en": "Complete the parallelogram — dashed lines from the tips of A and B.",
              "sync_point": "parallelogram_complete",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "parallelogram"
              ]
            },
            {
              "id": "s3",
              "text_en": "The diagonal from O is the resultant R. Not 7. This is the parallelogram law.",
              "sync_point": "diagonal_appears",
              "pause_after_ms": 800,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "parallelogram law",
                "resultant"
              ]
            }
          ]
        }
      },
      "STATE_3": {
        "state_id": "STATE_3",
        "label": "Triangle Law",
        "physics_layer": {
          "scenario": "triangle_law",
          "params": {
            "vec_a": {
              "magnitude": 4,
              "angle_deg": 0,
              "label": "A"
            },
            "vec_b": {
              "magnitude": 3,
              "angle_deg": 90,
              "label": "B"
            },
            "show_triangle": true,
            "show_resultant": true
          }
        },
        "panel_b_layer": {
          "scenario": "graph_empty_axes",
          "active_lines": [],
          "highlight_point": false
        },
        "advance_mode": "auto_after_animation",
        "locked_facts": [
          "Triangle law: head-to-tail; resultant connects tail of first to head of last",
          "Triangle law and parallelogram law give identical R"
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Second method — triangle law. Shift B so its tail sits at the tip of A.",
              "sync_point": "vectors_appear",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "triangle law"
              ]
            },
            {
              "id": "s2",
              "text_en": "The line from tail of A to tip of B is R. Same answer. Two methods — one result.",
              "sync_point": "diagonal_appears",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": []
            }
          ]
        }
      },
      "STATE_4": {
        "state_id": "STATE_4",
        "label": "Resultant Formula",
        "physics_layer": {
          "scenario": "resultant_formula",
          "params": {
            "vec_a": {
              "magnitude": 4,
              "angle_deg": 0,
              "label": "A"
            },
            "vec_b": {
              "magnitude": 3,
              "angle_deg": 60,
              "label": "B"
            },
            "show_formula": true,
            "interactive_theta": true
          },
          "freeze_at_t": 0
        },
        "panel_b_layer": {
          "scenario": "graph_single_dot",
          "active_lines": [],
          "highlight_point": true,
          "point_x": 60,
          "point_y": 7.0,
          "reference_points": []
        },
        "advance_mode": "interaction_complete",
        "locked_facts": [
          "R = √(A² + B² + 2AB cosθ)",
          "tan α = (B sinθ)/(A + B cosθ)",
          "cosθ term is zero at 90°, positive below, negative above"
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Apply the cosine rule to the triangle. R squared equals A squared plus B squared plus 2AB cosine theta.",
              "sync_point": "formula_overlaid",
              "pause_after_ms": 800,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "cosine theta"
              ]
            },
            {
              "id": "s2",
              "text_en": "The 2AB cosine theta term links the angle to the magnitude. Use the slider — watch R change live.",
              "sync_point": "slider_enabled",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "cosine theta",
                "slider"
              ]
            }
          ]
        }
      },
      "STATE_5": {
        "state_id": "STATE_5",
        "label": "Special Cases: 0°, 90°, 180°",
        "physics_layer": {
          "scenario": "special_cases_0_90_180",
          "params": {
            "vec_a_magnitude": 4,
            "vec_b_magnitude": 3,
            "cases": [
              0,
              90,
              180
            ],
            "highlight_max_min": true
          },
          "freeze_at_t": 0
        },
        "panel_b_layer": {
          "scenario": "graph_reference_points",
          "active_lines": [],
          "highlight_point": false,
          "reference_points": [
            {
              "x": 0,
              "y": 7,
              "label": "R_max"
            },
            {
              "x": 90,
              "y": 5,
              "label": "R_perp"
            },
            {
              "x": 180,
              "y": 1,
              "label": "R_min"
            }
          ]
        },
        "advance_mode": "auto_after_tts",
        "locked_facts": [
          "θ=0°: R_max=A+B=7",
          "θ=90°: R=√(A²+B²)=5 — Pythagoras, ONLY here",
          "θ=180°: R_min=|A−B|=1",
          "|A−B| ≤ R ≤ A+B"
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Three cases JEE loves. Same A=4, B=3 — three different resultants.",
              "sync_point": "special_cases_shown",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "JEE"
              ]
            },
            {
              "id": "s2",
              "text_en": "Zero degrees: R equals seven. Maximum.",
              "sync_point": "step_1_complete",
              "pause_after_ms": 400,
              "tts_style": "calm_explain",
              "no_translate_tokens": []
            },
            {
              "id": "s3",
              "text_en": "Ninety degrees: R equals five. Pythagoras. This shortcut works ONLY at ninety.",
              "sync_point": "step_2_complete",
              "pause_after_ms": 400,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "Pythagoras"
              ]
            },
            {
              "id": "s4",
              "text_en": "One-eighty degrees: R equals one. Minimum. The law: R always between modulus A minus B and A plus B.",
              "sync_point": "state_complete",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": []
            }
          ]
        }
      },
      "STATE_6": {
        "state_id": "STATE_6",
        "label": "R vs θ Full Curve",
        "physics_layer": {
          "scenario": "r_vs_theta_curve",
          "params": {
            "vec_a_magnitude": 4,
            "vec_b_magnitude": 3,
            "animate_theta": true
          }
        },
        "panel_b_layer": {
          "scenario": "graph_full_curve",
          "lines": [
            {
              "id": "r_vs_theta",
              "label": "R(θ)",
              "color": "#FF7043",
              "width": 2
            }
          ],
          "active_lines": [
            "r_vs_theta"
          ],
          "highlight_point": true,
          "x_axis": {
            "label": "Angle θ (degrees)",
            "min": 0,
            "max": 180,
            "tick_step": 30
          },
          "y_axis": {
            "label": "Resultant R",
            "min": 0,
            "max": 8
          },
          "pvl_colors": {
            "r_vs_theta": "#FF7043"
          }
        },
        "advance_mode": "auto_after_animation",
        "locked_facts": [
          "R(θ) is a smooth decreasing curve from A+B to |A−B|",
          "Curve follows R = √(A²+B²+2AB cosθ) — not linear"
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Now the full picture. Watch R trace its curve as theta sweeps zero to one-eighty.",
              "sync_point": "animation_start",
              "pause_after_ms": 400,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "theta"
              ]
            },
            {
              "id": "s2",
              "text_en": "Not linear. Bends — because cosine theta bends.",
              "sync_point": "curve_draws",
              "pause_after_ms": 600,
              "tts_style": "calm_explain",
              "no_translate_tokens": [
                "cosine theta"
              ]
            },
            {
              "id": "s3",
              "text_en": "Seven at zero. Five at ninety. One at one-eighty. Everything in between follows this one curve.",
              "sync_point": "state_complete",
              "pause_after_ms": 400,
              "tts_style": "energetic_aha",
              "no_translate_tokens": []
            }
          ]
        }
      }
    }
  },
  "epic_c_branches": [
    {
      "branch_id": "resultant_always_larger",
      "misconception": "The resultant of two vectors is always larger than both individual vectors",
      "student_belief": "Resultant toh hamesha dono se bada hoga — 4 aur 3 hai toh R 5 se zyada hoga zaroor",
      "trigger_phrases": [
        "always larger",
        "always bigger",
        "hamesha bada",
        "dono se zyada",
        "can't be less than either",
        "minimum toh A ya B se zyada hoga"
      ],
      "misconception_depth_signals": {
        "shallow": [
          "I thought it would be bigger",
          "mujhe laga zyada hoga",
          "7 nahi aaya"
        ],
        "deep": [
          "resultant can never be less than either vector",
          "vectors always increase when combined",
          "sirf bada ho sakta hai"
        ]
      },
      "sonnet_emphasis_per_state": {
        "S2": "Force student to watch R shrink below A=4 as theta increases — observe, not just describe",
        "S3": "R=1 is less than both A=4 and B=3 — this is the belief-breaking moment, make it land",
        "S4": "Same magnitudes, R ranges 1 to 7 — direction is the control knob, encode as new mental model",
        "S5": "Lock |A−B| ≤ R ≤ A+B as a formula the student writes down"
      },
      "states": [
        {
          "state_id": "S1",
          "label": "Wrong belief — shown live",
          "physics_layer": {
            "scenario": "va_wrong_always_larger",
            "show_students_wrong_belief": true,
            "freeze_at_t": 0
          },
          "panel_b_layer": {
            "scenario": "graph_wrong_region",
            "highlight_point": false
          },
          "advance_mode": "auto_after_tts",
          "locked_facts": [
            "At θ=0°, R=A+B=7 — student is locally correct for this special case"
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "You said the resultant is always larger. At zero degrees — parallel vectors — R equals seven. A plus B. You are right. Here.",
                "sync_point": "wrong_belief_shown",
                "pause_after_ms": 800,
                "tts_style": "calm_explain",
                "no_translate_tokens": []
              }
            ]
          }
        },
        {
          "state_id": "S2",
          "label": "Angle changes — R shrinks",
          "physics_layer": {
            "scenario": "va_angle_determines",
            "freeze_at_t": 0
          },
          "panel_b_layer": {
            "scenario": "graph_partial_curve",
            "highlight_point": true
          },
          "advance_mode": "auto_after_animation",
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Now watch as I rotate vector B. R is getting shorter. Same two vectors — but the resultant is shrinking.",
                "sync_point": "conflict_revealed",
                "pause_after_ms": 800,
                "tts_style": "calm_explain",
                "no_translate_tokens": []
              }
            ]
          }
        },
        {
          "state_id": "S3",
          "label": "Minimum — R below both",
          "physics_layer": {
            "scenario": "va_minimum_resultant",
            "freeze_at_t": 0
          },
          "panel_b_layer": {
            "scenario": "graph_single_dot",
            "highlight_point": true,
            "point_x": 180,
            "point_y": 1
          },
          "advance_mode": "auto_after_tts",
          "locked_facts": [
            "At θ=180°, R=|A−B|=1 — less than both A=4 and B=3"
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "One-eighty degrees. R equals one. Less than A which is four. Less than B which is three. The resultant is smaller than either vector alone.",
                "sync_point": "correct_shown",
                "pause_after_ms": 1000,
                "tts_style": "energetic_aha",
                "no_translate_tokens": []
              }
            ]
          }
        },
        {
          "state_id": "S4",
          "label": "Aha — direction is the control knob",
          "physics_layer": {
            "scenario": "va_aha_direction_controls",
            "freeze_at_t": 0
          },
          "panel_b_layer": {
            "scenario": "graph_full_curve",
            "highlight_point": false
          },
          "advance_mode": "auto_after_tts",
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Same A=4, same B=3. R ranges from one to seven — purely based on direction. Direction is the control knob. This is what makes vectors different from scalars.",
                "sync_point": "state_complete",
                "pause_after_ms": 600,
                "tts_style": "energetic_aha",
                "no_translate_tokens": [
                  "vectors",
                  "scalars"
                ]
              }
            ]
