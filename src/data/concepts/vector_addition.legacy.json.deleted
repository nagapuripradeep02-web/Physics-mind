{
  "concept_id": "vector_addition",
  "concept_name": "Vector Addition",
  "class_level": 11,
  "chapter": "Chapter 5: Vectors",
  "section": "5.1 – Addition of Vectors",
  "source_coverage": {
    "dc_pandey": {
      "volume": "Mechanics Vol 1",
      "chapter": 5,
      "sections": [
        "5.1",
        "5.2",
