                    "h": 75
                  }
                },
                {
                  "type": "force_arrow",
                  "magnitude": 588,
                  "direction_deg": 270,
                  "label": "Weight = 588 N",
                  "color": "#EF4444",
                  "scale_pixels_per_unit": 0.2,
                  "position": {
                    "x": 145,
                    "y": 215
                  }
                }
              ],
              "right_scene": [
                {
                  "type": "body",
                  "shape": "rect",
                  "label": "Mass = 60 kg\n(same!)",
                  "fill_color": "#6B7280",
                  "position": {
                    "x": 100,
                    "y": 140
                  },
                  "size": {
                    "w": 90,
                    "h": 75
                  }
                },
                {
                  "type": "force_arrow",
                  "magnitude": 96,
                  "direction_deg": 270,
                  "label": "Weight = 96 N",
                  "color": "#EF4444",
                  "scale_pixels_per_unit": 0.5,
                  "position": {
                    "x": 145,
                    "y": 215
                  }
                }
              ]
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Same body, same mass — but placed on two different planets."
              },
              {
                "id": "s2",
                "text_en": "On Earth the weight is five hundred eighty eight newtons. On the Moon it is only ninety six newtons — six times smaller."
              },
              {
                "id": "s3",
                "text_en": "The mass did not change at all. Only g changed."
              },
              {
                "id": "s4",
                "text_en": "If weight equaled mass, the Moon reading would still say sixty. It does not, because weight and mass are not the same quantity."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        },
        "EPIC_C_3": {
          "title": "Clear Now: Mass vs Weight",
          "scene_composition": [
