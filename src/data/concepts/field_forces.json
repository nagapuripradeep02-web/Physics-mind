        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Earth builds a gravitational field around itself. The dashed arrows show that field pointing inward."
            },
            {
              "id": "s2",
              "text_en": "The field is everywhere — above, below, left, right. Every direction is covered."
            },
            {
              "id": "s3",
              "text_en": "Drop any mass into this field and it immediately feels a downward pull. No touching required."
            },
            {
              "id": "s4",
              "text_en": "The field is the messenger. Forces travel through fields, which is how nature delivers a push without direct contact."
            }
          ]
        },
