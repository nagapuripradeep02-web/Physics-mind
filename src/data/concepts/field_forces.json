            "scale_pixels_per_unit": 10
          },
          {
            "type": "formula_box",
            "id": "weight_formula",
            "equation": "w = mg = 1 × 9.8 = 9.8 N",
            "position": {
              "x": 475,
              "y": 240
            },
            "border_color": "#EF4444"
          },
          {
            "type": "annotation",
            "text": "The downward pull of the gravitational field on a body\nis what we call its weight.",
            "position": {
              "x": 130,
              "y": 430
            },
            "style": "callout"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Put a one kilogram mass into the gravitational field. It immediately feels a downward pull of nine point eight newtons."
            },
            {
              "id": "s2",
              "text_en": "That specific force has a name: weight. Its formula is w equals m times g."
            },
            {
              "id": "s3",
              "text_en": "Here m is the body's mass and g is the strength of Earth's gravitational field at its surface."
            },
            {
              "id": "s4",
              "text_en": "Weight is a force, measured in newtons. It is not the same thing as mass, which is measured in kilograms."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
