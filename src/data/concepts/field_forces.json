    {
      "branch_id": "need_contact_for_force",
      "misconception": "A force can only act if the bodies are in physical contact.",
      "trigger_phrases": [
        "no contact means no force",
        "gravity needs touching",
        "how can force act without contact"
      ],
      "state_sequence": [
        "EPIC_C_1",
