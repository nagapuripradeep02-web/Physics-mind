        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "A mango falls from a tree. Nobody pushed it. No rope was attached."
            },
            {
              "id": "s2",
              "text_en": "Watch the gap between positions — it keeps getting larger. That is acceleration from gravity."
            },
            {
              "id": "s3",
              "text_en": "Everyone knows the name — gravity. Today we uncover how gravity actually works."
            },
            {
              "id": "s4",
              "text_en": "Because gravity belongs to a special family of forces — forces that act across empty space."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
