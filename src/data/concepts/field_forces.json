  "epic_c_branches": [
    {
      "branch_id": "weight_equals_mass",
      "misconception": "Weight and mass are the same thing — both measured in kilograms.",
      "trigger_phrases": [
        "my weight is 60 kg",
        "weight is 5 kg",
        "weight and mass are the same",
        "weight means how heavy"
      ],
      "state_sequence": [
        "EPIC_C_1",
        "EPIC_C_2",
        "EPIC_C_3"
      ],
      "states": {
        "EPIC_C_1": {
          "title": "Your Belief Visualized: Weight = Mass",
          "scene_composition": [
            {
              "type": "body",
              "id": "block",
              "shape": "rect",
              "label": "60 kg object",
              "position": {
                "x": 280,
                "y": 280
              },
              "size": {
                "w": 90,
                "h": 80
              },
              "fill_color": "#6B7280"
            },
            {
              "type": "label",
              "text": "Student's belief: 'Weight = 60 kg'",
              "position": {
                "x": 300,
                "y": 430
              },
              "font_size": 15,
              "color": "#EF4444"
            },
            {
              "type": "annotation",
              "text": "Weight is a FORCE.\nForces are measured in newtons, not kilograms.",
              "position": {
                "x": 560,
                "y": 220
              },
              "style": "callout",
              "color": "#F59E0B"
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "You are saying your weight is sixty kilograms. This is one of the most common mistakes in physics."
              },
              {
                "id": "s2",
                "text_en": "Weight is a force. Forces are measured in newtons, not kilograms."
              },
              {
                "id": "s3",
                "text_en": "Sixty kilograms is your mass — how much matter your body contains."
              },
              {
                "id": "s4",
                "text_en": "Your weight is sixty times nine point eight, which equals five hundred eighty eight newtons. That is the downward pull of gravity on you."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        },
        "EPIC_C_2": {
          "title": "The Moon Test — Mass Stays, Weight Changes",
          "scene_composition": [
            {
              "type": "comparison_panel",
              "id": "earth_moon_compare",
              "left_label": "Earth (g = 9.8 m/s²)",
              "right_label": "Moon (g = 1.6 m/s²)",
              "left_scene": [
                {
                  "type": "body",
