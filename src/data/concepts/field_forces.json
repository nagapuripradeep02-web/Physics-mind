          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Now the distinction is clear. Mass is a property of the body — a measure of matter."
              },
              {
                "id": "s2",
                "text_en": "Weight is a gravitational force — it depends on both m and g."
              },
              {
