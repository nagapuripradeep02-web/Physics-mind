            "color": "#EF4444"
          }
        ],
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "The center of Earth sits six thousand four hundred kilometers below the surface. The mango sits on a branch above."
            },
            {
              "id": "s2",
              "text_en": "There is no string between them, no solid contact. Only air fills the gap."
            },
            {
              "id": "s3",
              "text_en": "And yet Earth pulls the mango. The force crosses empty space as if the gap were not there."
            },
            {
              "id": "s4",
              "text_en": "This is the puzzle of field forces — distance alone cannot switch them off."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
      },
