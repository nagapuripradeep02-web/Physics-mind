      ],
      "states": {
        "EPIC_C_1": {
          "title": "Your Belief: No Contact Means No Force",
          "scene_composition": [
            {
              "type": "comparison_panel",
              "left_label": "Contact force (clear)",
              "right_label": "Field force (mysterious?)",
              "left_scene": [
                {
                  "type": "annotation",
                  "text": "A hand pushes a cart.\nTouching: YES.\nForce: obvious.",
                  "position": {
                    "x": 20,
                    "y": 120
                  }
                }
              ],
              "right_scene": [
                {
                  "type": "annotation",
                  "text": "Earth pulls a mango.\nTouching: NO.\nForce: still real.",
                  "position": {
                    "x": 20,
                    "y": 120
                  }
                }
              ]
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Your intuition says a force cannot exist without touching. That instinct is natural."
              },
              {
                "id": "s2",
                "text_en": "Push a table and it moves. Contact is visible. Cause and effect are obvious."
              },
              {
                "id": "s3",
                "text_en": "But nature has two families of forces — contact forces and field forces."
              },
              {
                "id": "s4",
