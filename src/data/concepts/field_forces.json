  "real_world_anchor": {
    "primary": "A mango falls from a tree. Nobody pushed it. Nothing was tied to it. Earth reaches across empty space and pulls it down.",
    "secondary": "A magnet attracts a paper clip through a pane of glass. No contact — the field does the work.",
    "tertiary": "A compass needle swings toward north with no wire, no touch. Earth's magnetic field is guiding it."
  },
  "physics_engine_config": {
    "formulas": {
      "weight": "w = m * g",
      "gravitational_field_strength": "g = 9.8"
    },
    "variables": {
      "m": {
        "name": "mass",
        "unit": "kg",
        "min": 0.1,
        "max": 10,
        "default": 1
      },
