  "epic_l_path": {
    "entry_state": "STATE_1",
    "exit_state": "STATE_6",
    "total_states": 6,
    "states": {
      "STATE_1": {
        "label": "Hook ‚ÄĒ A vector in 2D",
        "phase": 1,
        "script_intent": "Show a single vector A in 2D space. No decomposition yet. The question hangs: how do we describe where this arrow points using just numbers along known directions?",
        "physics_layer": {
          "scenario": "component_decomposition",
          "params": {
            "vec_a": {
              "magnitude": 5,
              "angle_deg": 37,
              "label": "A",
              "color": "#60a5fa"
            }
          },
          "freeze_at_t": 0,
          "show_drop_lines": false,
          "show_components": false
        },
        "panel_b_layer": {
          "scenario": "graph_empty_axes",
          "show_curve": false
        },
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1_01",
              "text_en": "Here is a vector A ‚ÄĒ five units long, pointing at 37 degrees from the x-axis.",
              "sync_point": "vector_appears",
              "tts_style": "calm_clear",
              "pause_after_ms": 800
            },
            {
              "id": "s1_02",
              "text_en": "It has a magnitude and a direction. But how do you describe it precisely to someone using only numbers?",
              "sync_point": "question_appears",
              "tts_style": "curious",
              "pause_after_ms": 1200
            },
            {
              "id": "s1_03",
              "text_en": "You break it into two parts ‚ÄĒ one along the x-axis and one along the y-axis. These are its components.",
              "sync_point": "hint_appears",
              "tts_style": "calm_clear",
              "pause_after_ms": 1000
            }
          ],
          "exam_tip_en": "Components are the x and y projections of a vector. Always identify the angle reference axis first.",
          "advance_mode": "manual_click"
        },
        "checkpoint_states": []
      },
      "STATE_2": {
        "label": "Drop the perpendicular lines",
        "phase": 1,
        "script_intent": "Drop dashed perpendicular lines from the tip of A to both axes. The x-intercept is Ax, the y-intercept is Ay. Students see the decomposition geometrically ‚ÄĒ it is a right triangle.",
        "physics_layer": {
          "scenario": "component_decomposition",
          "params": {
            "vec_a": {
              "magnitude": 5,
              "angle_deg": 37,
              "label": "A",
              "color": "#60a5fa"
            }
          },
          "freeze_at_t": 0,
          "show_drop_lines": true,
          "show_components": true
        },
        "panel_b_layer": {
          "scenario": "graph_empty_axes",
          "show_curve": false
        },
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s2_01",
              "text_en": "Drop a perpendicular from the tip of A to the x-axis. That length is Ax ‚ÄĒ the x-component.",
              "sync_point": "drop_line_x",
              "tts_style": "calm_clear",
              "pause_after_ms": 1000
            },
            {
              "id": "s2_02",
              "text_en": "Drop another perpendicular to the y-axis. That length is Ay ‚ÄĒ the y-component.",
              "sync_point": "drop_line_y",
              "tts_style": "calm_clear",
              "pause_after_ms": 1000
            },
            {
              "id": "s2_03",
              "text_en": "You have made a right triangle. A is the hypotenuse. Ax and Ay are the two legs.",
              "sync_point": "triangle_complete",
              "tts_style": "confident",
              "pause_after_ms": 1200
            }
          ],
          "exam_tip_en": "The vector, x-component, and y-component always form a right triangle. This is Pythagoras applied to direction.",
          "advance_mode": "manual_click"
        },
        "checkpoint_states": []
      },
      "STATE_3": {
        "label": "Ax = Acosőł, Ay = Asinőł",
        "phase": 1,
        "script_intent": "Show that Ax=Acosőł and Ay=Asinőł from the right triangle. Use slider to vary őł and watch components change live.",
        "physics_layer": {
          "scenario": "trig_component_formulas",
          "params": {
            "vec_a": {
              "magnitude": 5,
              "angle_deg": 37,
              "label": "A"
            },
            "default_theta": 37,
            "show_formula": true
          }
        },
        "panel_b_layer": {
          "scenario": "graph_empty_axes",
          "show_curve": false
        },
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s3_01",
              "text_en": "From the right triangle: Ax equals A cosine theta. Ay equals A sine theta. These come directly from trigonometry.",
              "sync_point": "formula_appears",
              "tts_style": "teaching",
              "pause_after_ms": 1200
            },
            {
              "id": "s3_02",
              "text_en": "Drag the slider. As theta increases from zero to ninety degrees, Ax shrinks and Ay grows.",
              "sync_point": "slider_prompt",
              "tts_style": "interactive",
              "pause_after_ms": 1000
            },
            {
              "id": "s3_03",
              "text_en": "At theta equals 45 degrees ‚ÄĒ something special happens. Ax equals Ay. Equal components. The vector splits evenly between both axes.",
              "sync_point": "theta_45_highlight",
              "tts_style": "excited",
              "pause_after_ms": 1500,
              "no_translate_tokens": [
                "theta",
                "Ax",
                "Ay"
              ]
            }
          ],
          "exam_tip_en": "Always check: which axis is theta measured from? If from y-axis, Ax=Asinőł and Ay=Acosőł. The formula swaps when the reference axis changes.",
          "advance_mode": "interaction_complete"
        },
        "checkpoint_states": []
      },
      "STATE_4": {
        "label": "The 3-4-5 trap",
        "phase": 2,
        "script_intent": "Show Ax=4, Ay=3. Ask: what is |A|? Students say 7. Canvas reveals the right triangle ‚ÄĒ |A|=5, not 7. Core misconception: scalar addition trap.",
        "physics_layer": {
          "scenario": "component_decomposition",
          "params": {
            "vec_a": {
              "magnitude": 5,
              "angle_deg": 37,
              "label": "A=5",
              "color": "#60a5fa"
            }
          },
          "freeze_at_t": 0,
          "show_drop_lines": true,
          "show_components": true
        },
        "panel_b_layer": {
          "scenario": "graph_two_curves",
          "show_curve": true,
          "highlight_point": true,
          "point_x": 36.87,
          "point_y": 3.0
        },
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s4_01",
              "text_en": "Ax equals 4. Ay equals 3. What is the magnitude of A? Most students say 4 plus 3 equals 7.",
              "sync_point": "question_posed",
              "tts_style": "calm_clear",
              "pause_after_ms": 1500
            },
            {
              "id": "s4_02",
              "text_en": "Wrong. Components do not add like scalars. A equals root of Ax squared plus Ay squared. Root of 16 plus 9. Root of 25. Five.",
              "sync_point": "formula_revealed",
              "tts_style": "emphatic",
              "pause_after_ms": 1500
            },
            {
              "id": "s4_03",
              "text_en": "This is the classic 3-4-5 right triangle. The components are the legs. The vector is the hypotenuse. Legs do not add ‚ÄĒ they combine by Pythagoras.",
              "sync_point": "triangle_shown",
              "tts_style": "teaching",
              "pause_after_ms": 1200,
              "no_translate_tokens": [
                "3-4-5"
              ]
            }
          ],
          "exam_tip_en": "NEVER add components directly. |A| = ‚ąö(Ax¬≤ + Ay¬≤). If Ax=3, Ay=4 ‚Üí |A|=5. This appears in JEE every year.",
          "advance_mode": "manual_click"
        },
        "checkpoint_states": [
          {
            "question": "If Ax = 6 and Ay = 8, what is |A|?",
            "correct_answer": "10",
            "distractor_answers": [
              "14",
              "‚ąö28",
              "7"
            ],
            "explanation": "|A| = ‚ąö(36+64) = ‚ąö100 = 10. Another Pythagorean triple: 6-8-10."
          }
        ]
      },
      "STATE_5": {
        "label": "Reconstruct A from components",
        "phase": 2,
        "script_intent": "Show reconstruction backwards: given Ax and Ay, build A. Reinforces that components are not separate things ‚ÄĒ they reconstruct the original exactly via A = Ax√ģ + AyńĶ.",
        "physics_layer": {
          "scenario": "reconstruction_from_components",
          "params": {
            "show_reconstruction": true
          },
          "freeze_at_t": 0
        },
        "panel_b_layer": {
          "scenario": "graph_two_curves",
          "show_curve": true,
          "highlight_point": true,
          "point_x": 36.87,
          "point_y": 3.0
        },
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s5_01",
              "text_en": "Now backwards. You know Ax and Ay. Can you recover A? Yes ‚ÄĒ by vector addition of the components.",
              "sync_point": "reconstruction_starts",
              "tts_style": "calm_clear",
              "pause_after_ms": 1000
            },
            {
              "id": "s5_02",
              "text_en": "A equals Ax i-hat plus Ay j-hat. The components are not separate from A ‚ÄĒ they reconstruct it exactly.",
              "sync_point": "formula_shown",
              "tts_style": "teaching",
              "pause_after_ms": 1200,
              "no_translate_tokens": [
                "i-hat",
                "j-hat"
              ]
            },
            {
              "id": "s5_03",
              "text_en": "This is why components are so powerful. Break any complex vector problem into x and y. Solve each axis separately. Recombine at the end.",
              "sync_point": "insight_shown",
              "tts_style": "confident",
              "pause_after_ms": 1500
            }
          ],
          "exam_tip_en": "A = Ax √ģ + Ay ńĶ is the vector form. Always write this in board exams ‚ÄĒ it shows the examiner you understand both magnitude and direction.",
          "advance_mode": "manual_click"
        },
        "checkpoint_states": []
      },
      "STATE_6": {
        "label": "Full interactive ‚ÄĒ drag őł and A",
        "phase": 3,
        "script_intent": "Full slider control: magnitude A (1-10) and angle őł (0-90). Panel B shows both sinusoidal curves with live dot on Ay curve. At őł=45¬į both components equal. At őł=0¬į all x, őł=90¬į all y.",
        "physics_layer": {
          "scenario": "trig_component_formulas",
          "params": {
            "default_theta": 37,
            "default_a": 5,
            "show_formula": true,
            "interactive": true
          }
        },
        "panel_b_layer": {
          "scenario": "graph_two_curves_live",
          "show_curve": true,
          "highlight_point": true,
          "point_x": 37,
          "point_y": 3.01
        },
        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s6_01",
              "text_en": "Your turn. Drag theta from zero to ninety. Watch Ax decrease as Ay increases. They trade off ‚ÄĒ the total length stays constant.",
              "sync_point": "slider_active",
              "tts_style": "interactive",
              "pause_after_ms": 1000
            },
            {
              "id": "s6_02",
              "text_en": "At 45 degrees: Ax equals Ay. The vector splits equally. The graph shows both curves crossing.",
              "sync_point": "theta_45",
              "tts_style": "excited",
              "pause_after_ms": 1200
            },
            {
              "id": "s6_03",
              "text_en": "Change the magnitude too. Larger A ‚ÄĒ both components scale up proportionally. The angle pattern stays the same.",
              "sync_point": "magnitude_change",
              "tts_style": "calm_clear",
              "pause_after_ms": 1000
            }
          ],
          "exam_tip_en": "The component-angle relationship is cosine for x, sine for y ‚ÄĒ always, when őł is measured from the x-axis.",
          "advance_mode": "interaction_complete"
        },
        "checkpoint_states": [
          {
            "question": "A force of 10N acts at 30¬į to the horizontal. What is the horizontal component?",
            "correct_answer": "10cos30¬į = 5‚ąö3 ‚Čą 8.66N",
            "distractor_answers": [
              "10sin30¬į = 5N",
              "10N",
              "10cos60¬į = 5N"
            ],
            "explanation": "Horizontal ‚Üí x-axis ‚Üí cosőł. F_x = Fcosőł = 10cos30¬į = 5‚ąö3 N."
          }
        ]
      }
    }
  },
