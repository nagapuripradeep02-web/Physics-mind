  "static_responses": {
    "unit_vector_definition": "A unit vector has magnitude exactly 1. √ģ, ńĶ, kŐā are unit vectors along x, y, z axes respectively. Any vector A = Ax √ģ + Ay ńĶ + Az kŐā.",
    "why_components_matter": "Components let you handle 2D and 3D problems by solving one axis at a time. Projectile motion: horizontal (x) has constant velocity, vertical (y) has gravity. Without components, you cannot separate them.",
    "negative_components": "A negative component is valid physics. F = ‚ąí12√ģ + 9ńĶ means 12N in the ‚ąíx direction and 9N in the +y direction. Negative just means opposite to the positive axis direction.",
    "3d_extension": "In 3D: A = Ax √ģ + Ay ńĶ + Az kŐā and |A| = ‚ąö(Ax¬≤+Ay¬≤+Az¬≤). Direction cosines: cosőĪ = Ax/A, coső≤ = Ay/A, coső≥ = Az/A."
  },
  "problem_guidance_path": {
    "entry_question": "A force of 15N acts at 37¬į from the negative x-axis towards the positive y-axis. Find its components.",
    "steps": [
      {
        "step": 1,
        "instruction": "Draw the vector. Identify the reference axis and the angle clearly.",
        "hint": "őł=37¬į from negative x-axis toward +y. Sketch this ‚ÄĒ the vector is in the second quadrant."
      },
      {
        "step": 2,
        "instruction": "Apply Ax = A cosőł, Ay = A sinőł. But check the quadrant for signs.",
        "hint": "Ax = ‚ąí15cos37¬į = ‚ąí12N (negative because ‚ąíx direction). Ay = +15sin37¬į = +9N."
      },
      {
        "step": 3,
        "instruction": "Write in unit vector form: F = Fx √ģ + Fy ńĶ",
        "hint": "F = ‚ąí12√ģ + 9ńĶ N"
      },
      {
        "step": 4,
        "instruction": "Verify magnitude: |F| = ‚ąö(Fx¬≤+Fy¬≤) = ‚ąö(144+81) = ‚ąö225 = 15N ‚úď",
        "hint": "Always verify ‚ÄĒ if magnitude doesn't match the given value, you made a sign error."
      }
    ]
  },
  "example_library": {
    "example_1": {
      "source": "DC Pandey Example 5.4",
      "problem": "A force F has magnitude 15N. Direction is at 37¬į from negative x-axis towards positive y-axis. Represent F in terms of √ģ and ńĶ.",
      "solution": "Fx = ‚ąíFcos37¬į = ‚ąí15√ó0.8 = ‚ąí12N. Fy = Fsin37¬į = 15√ó0.6 = 9N. F = (‚ąí12√ģ + 9ńĶ) N",
      "key_insight": "When angle is from negative axis, the component along that axis is negative. Always check quadrant.",
      "common_error": "Students write Fx = +12N ignoring the negative direction."
    },
    "example_2": {
      "source": "DC Pandey Example 5.6",
      "problem": "Resolve a weight of 10N in two directions parallel and perpendicular to a slope inclined at 30¬į to the horizontal.",
      "solution": "Perpendicular to slope: W‚ä• = Wcos30¬į = 10√ó(‚ąö3/2) = 5‚ąö3 ‚Čą 8.66N. Parallel to slope: W‚ą• = Wsin30¬į = 10√ó0.5 = 5N",
      "key_insight": "On an inclined plane, őł is measured from the slope (not the horizontal). Cos gives perpendicular, sin gives parallel.",
      "common_error": "Students use the wrong angle or swap perpendicular and parallel."
    },
    "example_3": {
      "source": "DC Pandey Example 5.7",
      "problem": "Resolve horizontally and vertically a force F=8N which makes an angle of 45¬į with the horizontal.",
      "solution": "FH = Fcos45¬į = 8√ó(1/‚ąö2) = 4‚ąö2 ‚Čą 5.66N. FV = Fsin45¬į = 8√ó(1/‚ąö2) = 4‚ąö2 ‚Čą 5.66N",
      "key_insight": "At 45¬į both components are equal. The vector splits evenly. This is the crossover point on the Ax vs Ay graph.",
      "common_error": "Students expect one component to be larger than the other at 45¬į."
    },
    "example_4": {
      "source": "DC Pandey Example 5.5",
      "problem": "Find magnitude and direction of vector A = (‚ąí6√ģ + 8ńĶ).",
      "solution": "|A| = ‚ąö(36+64) = ‚ąö100 = 10 units. tan őł = 8/6 ‚Üí őł = 53.13¬į above ‚ąíx axis (second quadrant).",
      "key_insight": "When components are given directly, use Pythagoras for magnitude. Check quadrant from signs of components.",
      "common_error": "Students compute 6+8=14 instead of ‚ąö(36+64)=10."
    }
  },
  "assessment_path": {
    "questions": [
      {
        "id": "q1",
        "question": "A vector A has magnitude 10 units at őł=37¬į from x-axis. What is Ax?",
        "correct_answer": "10cos37¬į = 8 units",
        "distractors": [
          {
            "answer": "10sin37¬į = 6 units",
            "maps_to_branch": "cos_sin_confusion",
            "error": "Used sin instead of cos for x-component"
          },
          {
            "answer": "10 units",
            "maps_to_branch": "component_equals_original",
            "error": "Thinks component equals full vector"
          },
          {
            "answer": "10√ó37/90 = 4.1 units",
            "maps_to_branch": "wrong_angle_reference",
            "error": "Proportional reasoning, not trigonometry"
          }
        ]
      },
      {
        "id": "q2",
        "question": "If Ax=3 and Ay=4, what is |A|?",
        "correct_answer": "‚ąö(9+16) = 5",
        "distractors": [
          {
            "answer": "7",
            "maps_to_branch": "scalar_addition_trap",
            "error": "Added components directly"
          },
          {
            "answer": "4 (just Ay)",
            "maps_to_branch": "component_equals_original",
            "error": "Took larger component as magnitude"
          },
          {
            "answer": "3.5",
            "maps_to_branch": "wrong_angle_reference",
            "error": "Averaged the components"
          }
        ]
      },
      {
        "id": "q3",
        "question": "A force of 20N acts at 30¬į from the positive y-axis (toward +x). What is its x-component?",
        "correct_answer": "20sin30¬į = 10N (őł from y-axis ‚Üí sin for x-component)",
        "distractors": [
          {
            "answer": "20cos30¬į = 17.3N",
            "maps_to_branch": "wrong_angle_reference",
            "error": "Used cosine even though angle is from y-axis"
          },
          {
            "answer": "20N",
            "maps_to_branch": "component_equals_original",
            "error": "Thinks component equals full vector"
          },
          {
            "answer": "10N but by wrong method",
            "maps_to_branch": "cos_sin_confusion",
            "error": "Got right answer by accident with wrong formula"
          }
        ]
      },
      {
        "id": "q4",
        "question": "What is the y-component of a 5N force directed along the positive x-axis?",
        "correct_answer": "0N ‚ÄĒ a horizontal vector has no vertical component",
        "distractors": [
          {
            "answer": "5N",
            "maps_to_branch": "component_equals_original",
            "error": "Thinks component equals vector"
          },
          {
            "answer": "5sin0¬į = 0N (correct method)",
            "maps_to_branch": null,
            "error": null
          },
          {
            "answer": "Cannot determine",
            "maps_to_branch": "wrong_angle_reference",
            "error": "Does not know őł=0¬į for horizontal"
          }
        ]
      },
      {
        "id": "q5",
        "question": "Vector A = 3√ģ + 4ńĶ. What is the angle it makes with the x-axis?",
        "correct_answer": "tan‚ĀĽ¬Ļ(4/3) = tan‚ĀĽ¬Ļ(Ay/Ax) ‚Čą 53¬į",
        "distractors": [
          {
            "answer": "tan‚ĀĽ¬Ļ(3/4) = 37¬į",
            "maps_to_branch": "cos_sin_confusion",
            "error": "Inverted the ratio ‚ÄĒ used Ax/Ay instead of Ay/Ax"
          },
          {
            "answer": "90¬į",
            "maps_to_branch": "component_equals_original",
            "error": "Confused component direction with vector direction"
          },
          {
            "answer": "53.13¬į",
            "maps_to_branch": null,
            "error": null
          }
        ]
      }
    ]
  },
