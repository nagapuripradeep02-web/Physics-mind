        "teacher_script": {
          "tts_sentences": [
            {
              "id": "s1",
              "text_en": "Three blocks stacked on each other. You are asked to find the forces everywhere."
            },
            {
              "id": "s2",
              "text_en": "Trying to draw everything in one picture gets confusing fast. Which normal reaction belongs to which pair? Where does each weight act?"
            },
            {
              "id": "s3",
              "text_en": "The free body diagram answers this by looking at only one body at a time. All other bodies are temporarily ignored."
            },
            {
              "id": "s4",
              "text_en": "This is a technique, not a trick. It is the first step in every single exam problem involving forces."
            }
          ]
        },
        "advance_mode": "auto_after_tts"
