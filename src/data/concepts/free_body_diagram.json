  "real_world_anchor": {
    "primary": "Three blocks stacked on each other. Showing every force in one picture is chaos. A free body diagram says: look at one body at a time.",
    "secondary": "A ladder leaning on a wall. Drawing every force at once confuses even experts. Isolate the ladder and only its own forces remain.",
    "tertiary": "A JEE problem with five bodies connected together. Writing Newton's law is impossible without a free body diagram first."
  },
  "physics_engine_config": {
    "variables": {
      "m": {
        "name": "mass",
        "unit": "kg",
        "min": 0.5,
        "max": 10,
        "default": 2
      },
      "theta": {
        "name": "incline angle",
        "unit": "degrees",
        "min": 0,
        "max": 60,
        "default": 0
      },
      "scenario_type": {
        "name": "scenario",
        "unit": "",
        "min": 0,
        "max": 1,
        "default": 0
      }
    },
    "formulas": {
      "equilibrium": "ΣF = 0 (static equilibrium)",
      "newtons_second": "ΣF = ma (if accelerating)",
      "sum_x": "ΣFx = max",
      "sum_y": "ΣFy = may"
    },
    "fbd_rules": [
      "Rule 1: Isolate EXACTLY ONE body (or sub-system). Never two bodies together.",
      "Rule 2: Show ALL forces on that body — every single one, no exceptions.",
      "Rule 3: Weight (mg) always acts downward through the center of mass.",
      "Rule 4: Every removed contact or connection becomes a force arrow.",
      "Rule 5: Do NOT show forces that the body exerts on others — only forces ON the body.",
      "Rule 6: Label every force with its symbol and direction."
    ],
    "force_checklist": [
      "Weight (mg) — always present if the body has mass",
      "Normal reaction (N) — from every surface in contact",
      "Friction (f) — from every rough surface in contact",
      "Tension (T) — from every string or rope attached",
      "Hinge force (H, V) — if a pin joint is present",
      "Applied force (F) — any external push or pull",
      "Spring force (kx) — if a spring is attached"
    ]
  },
