    {
      "branch_id": "gravity_acts_at_contact_point",
      "misconception": "Gravity acts where the body is held or supported.",
      "trigger_phrases": [
        "weight acts at the bottom",
        "gravity acts at the support point",
        "weight acts at contact"
      ],
      "state_sequence": [
        "EPIC_C_1"
      ],
      "states": {
        "EPIC_C_1": {
          "title": "Gravity Always Acts at the Center of Mass — Nowhere Else",
          "scene_composition": [
            {
              "type": "comparison_panel",
              "left_label": "Belief: weight at the support point",
              "right_label": "Reality: weight at the center of mass",
              "left_scene": [
                {
                  "type": "body",
                  "shape": "rect",
                  "label": "Block",
                  "fill_color": "#6B7280",
                  "position": {
                    "x": 100,
                    "y": 120
                  },
                  "size": {
                    "w": 100,
                    "h": 80
                  }
                },
                {
                  "type": "force_arrow",
                  "magnitude": 20,
                  "direction_deg": 270,
                  "label": "mg? (bottom)",
                  "color": "#EF4444",
                  "scale_pixels_per_unit": 2,
                  "position": {
                    "x": 150,
                    "y": 200
                  }
                },
                {
                  "type": "annotation",
                  "text": "Wrong. Gravity is not a contact force.\nIt acts through the center of mass.",
                  "color": "#EF4444",
                  "position": {
                    "x": 20,
                    "y": 250
                  }
                }
              ],
              "right_scene": [
                {
                  "type": "body",
                  "shape": "rect",
                  "label": "Block",
                  "fill_color": "#6B7280",
                  "position": {
                    "x": 100,
                    "y": 120
                  },
                  "size": {
                    "w": 100,
                    "h": 80
                  }
                },
                {
                  "type": "force_arrow",
                  "magnitude": 20,
                  "direction_deg": 270,
                  "label": "mg (center of mass)",
                  "color": "#EF4444",
                  "scale_pixels_per_unit": 2,
                  "position": {
                    "x": 150,
                    "y": 160
                  }
                },
                {
                  "type": "annotation",
                  "text": "Correct. mg acts at the center of mass, always pointing down.",
                  "color": "#10B981",
                  "position": {
                    "x": 20,
                    "y": 250
                  }
                }
              ]
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "Gravity is a field force. It does not need contact to act."
              },
              {
                "id": "s2",
                "text_en": "That is why gravity acts on the center of mass of a body, not on its support point or contact point."
              },
              {
                "id": "s3",
                "text_en": "Whether a table is under the block or not, mg still points straight down from the block's center."
              },
              {
                "id": "s4",
                "text_en": "In every FBD, draw the mg arrow starting at the geometric center of the body, pointing down."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        }
      }
