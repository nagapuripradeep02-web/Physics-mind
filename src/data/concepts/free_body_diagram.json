    {
      "branch_id": "missing_normal_force_in_fbd",
      "misconception": "The free body diagram only needs to show the weight.",
      "trigger_phrases": [
        "only weight in FBD",
        "why show N",
        "gravity is the only force"
      ],
      "state_sequence": [
        "EPIC_C_1"
      ],
      "states": {
        "EPIC_C_1": {
          "title": "Missing N = Wrong Equation = Wrong Answer",
          "scene_composition": [
            {
              "type": "comparison_panel",
              "left_label": "Incomplete FBD (N missing)",
              "right_label": "Complete FBD",
              "left_scene": [
                {
                  "type": "body",
                  "shape": "rect",
                  "label": "Book on table",
                  "fill_color": "#3B82F6",
                  "position": {
                    "x": 100,
                    "y": 130
                  },
                  "size": {
                    "w": 100,
                    "h": 70
                  }
                },
                {
                  "type": "force_arrow",
                  "magnitude": 15,
                  "direction_deg": 270,
                  "label": "mg (only)",
                  "color": "#EF4444",
                  "scale_pixels_per_unit": 3,
                  "position": {
                    "x": 150,
                    "y": 165
                  }
                },
                {
                  "type": "annotation",
                  "text": "ΣFy = −mg ≠ 0.\nEquation says the book accelerates down —\nbut it is sitting still. Contradiction.",
                  "color": "#EF4444",
                  "position": {
                    "x": 20,
                    "y": 250
                  }
                }
              ],
              "right_scene": [
                {
                  "type": "body",
                  "shape": "rect",
                  "label": "Book on table",
                  "fill_color": "#3B82F6",
                  "position": {
                    "x": 100,
                    "y": 130
                  },
                  "size": {
                    "w": 100,
                    "h": 70
                  }
                },
                {
                  "type": "force_arrow",
                  "magnitude": 15,
                  "direction_deg": 270,
                  "label": "mg",
                  "color": "#EF4444",
                  "scale_pixels_per_unit": 3,
                  "position": {
                    "x": 150,
                    "y": 165
                  }
                },
                {
                  "type": "force_arrow",
                  "magnitude": 15,
                  "direction_deg": 90,
                  "label": "N (must be shown)",
                  "color": "#10B981",
                  "scale_pixels_per_unit": 3,
                  "position": {
                    "x": 150,
                    "y": 165
                  }
                },
                {
                  "type": "annotation",
                  "text": "ΣFy = N − mg = 0. The book is stationary. Correct.",
                  "color": "#10B981",
                  "position": {
                    "x": 20,
                    "y": 250
                  }
                }
              ]
            }
          ],
          "teacher_script": {
            "tts_sentences": [
              {
                "id": "s1",
                "text_en": "If you show only mg, your equation says the net force is downward and the book should fall. But the book is not falling — something is wrong."
              },
              {
                "id": "s2",
                "text_en": "The missing force is N, the upward push of the table. That must always be shown in the diagram."
              },
              {
                "id": "s3",
                "text_en": "The rule is simple. Every physical contact becomes one normal reaction arrow. Table contact means N upward."
              },
              {
                "id": "s4",
                "text_en": "Missing a force means a wrong equation, which means a wrong answer. The FBD must be complete."
              }
            ]
          },
          "advance_mode": "auto_after_tts"
        }
      }
    }
